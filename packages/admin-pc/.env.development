# 【开发】环境变量

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# API 请求基础路径（走 Vite 代理 → VITE_API_PROXY_TARGET）
# VITE_API_BASE_URL 为全栈统一命名；VITE_API_URL 保留作为旧 fallback
VITE_API_BASE_URL = /
VITE_API_URL = /

# 代理目标地址 —— 后端统一入口 https://ewsn.top
# 本地不再起 server,所有 /api 请求由 Vite dev server 反代到线上后端
# VITE_API_PROXY_TARGET 为统一命名；VITE_API_PROXY_URL 保留作为旧 fallback
VITE_API_PROXY_TARGET = https://ewsn.top
VITE_API_PROXY_URL = https://ewsn.top

# Delete console
VITE_DROP_CONSOLE = false
