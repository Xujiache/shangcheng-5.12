# 【开发】环境变量

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# API 请求基础路径（走 Vite 代理 → VITE_API_PROXY_URL）
VITE_API_URL = /

# 代理目标地址（本地真后端）
VITE_API_PROXY_URL = http://localhost:3001

# Mock 开关：false=连真后端 / true=本地 MOCK_ACCOUNTS
VITE_USE_MOCK = false

# Delete console
VITE_DROP_CONSOLE = false
