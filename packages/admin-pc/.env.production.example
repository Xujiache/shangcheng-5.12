# 【生产 · 部署到任意域名时复制为 .env.production 并按需调整】

# 应用挂载基础路径（nginx 把这个前缀的 alias 指向 dist/）
VITE_BASE_URL = /admin/

# API 同源
# 后端统一入口 https://ewsn.top
# 生产部署如果 admin-pc 和后端在同域,可设为 /;跨域必须显式写完整域名
# VITE_API_BASE_URL 为全栈统一命名；VITE_API_URL 保留作为旧 fallback
VITE_API_BASE_URL = https://ewsn.top
VITE_API_URL = https://ewsn.top

VITE_WITH_CREDENTIALS = false

# 菜单模式：frontend = 走前端静态菜单 + 角色过滤
VITE_ACCESS_MODE = frontend

VITE_USE_MOCK = false
VITE_DROP_CONSOLE = true
