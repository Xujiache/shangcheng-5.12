{
  "pages": [
    { "path": "pages/tabbar/home/index", "style": { "navigationBarTitleText": "经纬科技" } },
    { "path": "pages/tabbar/category/index", "style": { "navigationBarTitleText": "分类" } },
    { "path": "pages/tabbar/cart/index", "style": { "navigationBarTitleText": "购物车" } },
    { "path": "pages/tabbar/me/index", "style": { "navigationBarTitleText": "我的" } },
    { "path": "pages/product/detail", "style": { "navigationBarTitleText": "商品详情" } },
    {
      "path": "pages/product/list",
      "style": { "navigationBarTitleText": "商品列表", "enablePullDownRefresh": true }
    },
    { "path": "pages/auth/login", "style": { "navigationBarTitleText": "登录" } }
  ],
  "subPackages": [
    {
      "root": "pages/order",
      "pages": [
        { "path": "confirm", "style": { "navigationBarTitleText": "确认订单" } },
        { "path": "pay", "style": { "navigationBarTitleText": "支付" } },
        { "path": "list", "style": { "navigationBarTitleText": "我的订单" } },
        { "path": "detail", "style": { "navigationBarTitleText": "订单详情" } }
      ]
    },
    {
      "root": "pages/address",
      "pages": [
        { "path": "list", "style": { "navigationBarTitleText": "收货地址" } },
        { "path": "edit", "style": { "navigationBarTitleText": "编辑地址" } }
      ]
    },
    {
      "root": "pages/me",
      "pages": [{ "path": "edit", "style": { "navigationBarTitleText": "个人信息" } }]
    },
    {
      "root": "pages/search",
      "pages": [
        {
          "path": "index",
          "style": { "navigationBarTitleText": "搜索", "navigationStyle": "custom" }
        },
        {
          "path": "result",
          "style": { "navigationBarTitleText": "搜索结果", "navigationStyle": "custom" }
        }
      ]
    },
    {
      "root": "pages/store",
      "pages": [
        { "path": "map", "style": { "navigationBarTitleText": "门店地址" } },
        { "path": "list", "style": { "navigationBarTitleText": "附近门店" } }
      ]
    },
    {
      "root": "pages/favorite",
      "pages": [{ "path": "list", "style": { "navigationBarTitleText": "我的收藏" } }]
    },
    {
      "root": "pages/coupon",
      "pages": [
        { "path": "center", "style": { "navigationBarTitleText": "领券中心" } },
        { "path": "my", "style": { "navigationBarTitleText": "我的优惠券" } }
      ]
    },
    {
      "root": "pages/merchant",
      "pages": [{ "path": "apply", "style": { "navigationBarTitleText": "商家入驻" } }]
    },
    {
      "root": "pages/channel",
      "pages": [{ "path": "index", "style": { "navigationBarTitleText": "频道" } }]
    },
    {
      "root": "pages/chat",
      "pages": [{ "path": "index", "style": { "navigationBarTitleText": "在线客服" } }]
    },
    {
      "root": "pages/booking",
      "pages": [{ "path": "index", "style": { "navigationBarTitleText": "预约量尺" } }]
    },
    {
      "root": "pages/promote",
      "pages": [{ "path": "index", "style": { "navigationBarTitleText": "推广分佣" } }]
    },
    {
      "root": "pages/share",
      "pages": [{ "path": "order", "style": { "navigationBarTitleText": "订单详情" } }]
    }
  ],
  "preloadRule": {
    "pages/tabbar/me/index": {
      "network": "all",
      "packages": ["pages/order", "pages/me", "pages/address"]
    },
    "pages/product/detail": {
      "network": "all",
      "packages": ["pages/order", "pages/chat"]
    }
  },
  "globalStyle": {
    "navigationStyle": "custom",
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "经纬科技",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F7F8FA"
  },
  "tabBar": {
    "custom": true,
    "color": "#86909C",
    "selectedColor": "#FF4D2D",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "list": [
      { "pagePath": "pages/tabbar/home/index", "text": "首页" },
      { "pagePath": "pages/tabbar/category/index", "text": "分类" },
      { "pagePath": "pages/tabbar/cart/index", "text": "购物车" },
      { "pagePath": "pages/tabbar/me/index", "text": "我的" }
    ]
  }
}
