<view class="bars" style="height: {{height + 22}}px;">
  <view
    wx:for="{{bars}}"
    wx:key="i"
    class="bars__col"
    style="opacity: {{highlight < 0 || highlight === index ? 1 : 0.42}};"
    data-index="{{index}}"
    bindtap="onSel"
  >
    <view class="bars__stack" style="height: {{height}}px;">
      <view class="bars__bar" style="height: {{item.h}}px; background: {{c1}};"></view>
      <view wx:if="{{grouped}}" class="bars__bar bars__bar--2" style="height: {{item.h2}}px; background: {{c2}};"></view>
    </view>
    <text class="bars__label {{highlight === index ? 'on' : ''}}">{{item.label}}</text>
  </view>
</view>
