<view
  class="seg {{dragging ? 'seg--drag' : ''}}"
  bindtouchstart="onTouchStart"
  catchtouchmove="onTouchMove"
  bindtouchend="onTouchEnd"
  bindtouchcancel="onTouchEnd"
>
  <view
    class="seg__ind"
    style="left: calc(3px + {{dragging ? dragIdx : idx}} * (100% - 6px) / {{count}}); width: calc((100% - 6px) / {{count}});"
  ></view>
  <view
    wx:for="{{options}}"
    wx:key="value"
    class="seg__btn {{(dragging ? dragIdx : idx) === index ? 'seg__btn--on' : ''}}"
    >{{item.label}}</view
  >
</view>
