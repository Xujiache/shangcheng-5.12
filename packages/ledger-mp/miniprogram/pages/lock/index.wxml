<lz-bg />
<view class="lk">
  <view class="lk__card">
    <view class="lk__icon"><lz-icon name="finger" size="36" color="accent" stroke="1.6" /></view>
    <view class="lk__title">门窗利账已锁定</view>
    <view class="lk__sub">{{supported ? '已开启生物解锁，请验证指纹 / 面容后继续' : '当前设备不支持指纹 / 面容验证，请退出登录后用密码重新登录，并在隐私设置中关闭生物解锁'}}</view>
    <button wx:if="{{supported}}" class="lz-btn lz-btn--primary lz-btn--lg lz-btn--full" bindtap="onRetry">
      {{verifying ? '验证中…' : '点击验证'}}
    </button>
    <button wx:else class="lz-btn lz-btn--primary lz-btn--lg lz-btn--full" bindtap="onLogout">退出登录</button>
    <view wx:if="{{supported}}" class="lk__logout" hover-class="tap-active" bindtap="onLogout">退出登录</view>
  </view>
</view>
