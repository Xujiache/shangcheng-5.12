<lz-bg />
<view class="mc">
  <lz-header title="消息中心">
    <view wx:if="{{hasUnread}}" slot="right" class="mc__readall" hover-class="tap-active" bindtap="onReadAll">全部已读</view>
  </lz-header>

  <view class="lz-page" style="padding-bottom: 40px;">
    <!-- 加载失败（网络等）：带重试，不与"暂无消息"空态混淆 -->
    <view wx:if="{{loadError}}" class="lz-card" style="text-align: center;">
      <view class="lz-muted" style="font-size: 14px; margin-bottom: 16px;">加载失败，请检查网络后重试</view>
      <button class="lz-btn lz-btn--ghost lz-btn--lg" bindtap="retry">重试</button>
    </view>
    <view wx:elif="{{list.length}}" class="mc__list">
      <view
        wx:for="{{list}}"
        wx:key="id"
        class="mc__item {{item.unread ? 'unread' : ''}}"
        data-id="{{item.id}}"
        bindtap="onRead"
        hover-class="tap-active"
      >
        <view class="mc__icon" style="background: {{item.tint}};">
          <lz-icon name="{{item.icon}}" size="18" color="{{item.color}}" />
        </view>
        <view class="mc__body">
          <view class="mc__top">
            <text class="mc__title">{{item.title}}</text>
            <view wx:if="{{item.unread}}" class="mc__dot"></view>
          </view>
          <view class="mc__text">{{item.body}}</view>
          <view class="mc__time">{{item.time}}</view>
        </view>
      </view>
    </view>
    <view wx:elif="{{!loading}}" class="lz-empty">暂无消息</view>
  </view>
</view>
