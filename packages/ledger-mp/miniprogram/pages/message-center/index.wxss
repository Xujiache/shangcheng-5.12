.mc__readall {
  font-size: 13.5px;
  font-weight: 600;
  color: var(--accent-text);
}
.mc__list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.mc__item {
  display: flex;
  gap: 12px;
  padding: 14px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-soft);
}
.mc__item.unread {
  background: var(--surface-up);
}
.mc__icon {
  width: 36px;
  height: 36px;
  border-radius: 11px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.mc__body {
  flex: 1;
  min-width: 0;
}
.mc__top {
  display: flex;
  align-items: center;
  gap: 7px;
}
.mc__title {
  font-size: 14.5px;
  font-weight: 600;
  color: var(--text);
}
.mc__dot {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: var(--loss);
  flex-shrink: 0;
}
.mc__text {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.5;
  margin-top: 4px;
}
.mc__time {
  font-size: 11.5px;
  color: var(--faint);
  margin-top: 6px;
}
