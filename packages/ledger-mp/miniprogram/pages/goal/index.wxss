.gl {
  min-height: 100vh;
  background: transparent;
}
.gl__prog {
  margin-bottom: 2px;
}
.gl__prog-t {
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
}
.gl__prog-s {
  font-size: 11.5px;
  color: var(--faint);
  margin-top: 9px;
  font-variant-numeric: tabular-nums;
}
.gl__divider {
  height: 1px;
  background: var(--border);
  margin: 16px 0;
}
.gl__fields {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.gl__field-icon {
  width: 32px;
  height: 32px;
  border-radius: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: var(--accent-soft);
}
.gl__field-label {
  font-size: 15px;
  color: var(--text);
  font-weight: 500;
  flex-shrink: 0;
}
.gl__cur {
  font-size: 15px;
  color: var(--faint);
  margin-left: auto;
}
.gl__input {
  flex: 0 1 auto;
  max-width: 46%;
  text-align: right;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}
.gl__ph {
  color: var(--faint);
  font-weight: 500;
}
.gl__note {
  font-size: 11.5px;
  color: var(--faint);
  text-align: center;
  padding: 16px 10px 4px;
  line-height: 1.6;
}
