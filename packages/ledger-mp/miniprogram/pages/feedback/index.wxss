.fb__textwrap {
  position: relative;
  padding: 14px 16px 26px;
}
.fb__textarea {
  width: 100%;
  min-height: 120px;
  font-size: 15px;
  color: var(--text);
  line-height: 1.6;
}
.fb__count {
  position: absolute;
  right: 16px;
  bottom: 12px;
  font-size: 11.5px;
  color: var(--faint);
}
.ph {
  color: var(--faint);
}

/* 图片网格 */
.fb__grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.fb__thumb {
  position: relative;
  width: 92px;
  height: 92px;
  border-radius: 12px;
  overflow: hidden;
}
.fb__thumb image {
  width: 100%;
  height: 100%;
  display: block;
}
.fb__thumb-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 22px;
  height: 22px;
  border-radius: 0 12px 0 12px;
  background: rgba(8, 24, 18, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
}
.fb__add {
  width: 92px;
  height: 92px;
  border-radius: 12px;
  border: 1px dashed var(--border-strong);
  background: var(--surface-2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
}
.fb__add-t {
  font-size: 12px;
  color: var(--faint);
}
.fb__note {
  font-size: 12px;
  color: var(--faint);
  line-height: 1.6;
  padding: 16px 8px 4px;
}
