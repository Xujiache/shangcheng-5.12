.fb__textwrap {
  position: relative;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-card);
  box-shadow: var(--shadow-soft);
  padding: 14px 16px 26px;
}
.fb__textarea {
  width: 100%;
  min-height: 120px;
  font-size: 15px;
  color: var(--text);
  line-height: 1.6;
}
.fb__count {
  position: absolute;
  right: 14px;
  bottom: 10px;
  font-size: 11.5px;
  color: var(--faint);
}
.ph {
  color: var(--faint);
}
.fb__note {
  font-size: 12px;
  color: var(--faint);
  line-height: 1.6;
  padding: 14px 8px 4px;
}
