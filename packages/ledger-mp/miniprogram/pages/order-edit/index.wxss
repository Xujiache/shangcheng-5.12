.oe__cancel {
  font-size: 15px;
  color: var(--muted);
}
.oe__lbl {
  font-size: 14.5px;
  color: var(--text);
  width: 64px;
}
.oe__pick {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
  margin-right: 4px;
}
.oe__pick--ph {
  color: var(--faint);
  font-weight: 400;
}
.oe__val {
  font-size: 15px;
  color: var(--text);
}
.oe__amt {
  display: flex;
  align-items: baseline;
  gap: 2px;
}
.oe__cur {
  font-size: 14px;
  color: var(--muted);
}
.oe__amt-in {
  min-width: 60px;
  width: 120px;
  text-align: right;
  font-size: 16.5px;
  font-weight: 600;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}
.oe__amt-in--accent {
  font-size: 19px;
  font-weight: 800;
  color: var(--accent-text);
}
.oe__amt-in--ex {
  width: 82px;
}
.ph {
  color: var(--faint);
}
.oe__sec {
  margin-top: var(--gap);
}
.oe__sec-t {
  font-size: 12.5px;
  color: var(--muted);
  font-weight: 500;
}
.oe__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.oe__cell {
  border: 1px solid var(--border);
  border-radius: var(--r-btn);
  background: var(--surface);
  padding: 12px;
  box-shadow: var(--shadow-soft);
}
.oe__cell-hd {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 9px;
}
.oe__cell-n {
  font-size: 12.5px;
  color: var(--muted);
}
.oe__cell-x {
  width: 20px;
  height: 20px;
  border-radius: 999px;
  background: var(--track);
  display: flex;
  align-items: center;
  justify-content: center;
}
.oe__cell-amt {
  display: flex;
  align-items: baseline;
  gap: 2px;
}
.oe__cell-amt .oe__amt-in {
  width: 100%;
  font-size: 19px;
  font-weight: 700;
}
.oe__add {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
  align-items: center;
}
.oe__addex {
  display: flex;
  align-items: center;
  gap: 4px;
  color: var(--accent-text);
  font-size: 13px;
  font-weight: 600;
}
.oe__extype {
  display: flex;
  align-items: center;
  gap: 4px;
  border: 1px solid var(--border);
  border-radius: var(--r-btn);
  background: var(--surface-2);
  color: var(--text);
  font-size: 13.5px;
  padding: 7px 10px;
}
.oe__exdel {
  width: 28px;
  height: 28px;
  border-radius: 999px;
  background: var(--track);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8px;
}
.oe__note {
  flex: 1;
  text-align: right;
  font-size: 14.5px;
  color: var(--text);
}
/* picker sheet */
.oe__mask {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
}
.oe__sheet {
  width: 100%;
  max-height: 76vh;
  background: var(--surface);
  border-radius: 24px 24px 0 0;
  display: flex;
  flex-direction: column;
  animation: sheetUp 0.28s cubic-bezier(0.22, 1, 0.36, 1);
}
.oe__sheet-hd {
  display: flex;
  align-items: center;
  padding: 16px 18px 12px;
}
.oe__sheet-t {
  font-size: 16px;
  font-weight: 700;
}
.oe__newc {
  display: flex;
  align-items: center;
  gap: 4px;
  background: var(--accent-soft);
  color: var(--accent-text);
  padding: 7px 13px;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 600;
}
.oe__sheet-search {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 0 18px 12px;
  background: var(--surface-2);
  border-radius: 12px;
  padding: 9px 12px;
  border: 1px solid var(--border);
}
.oe__sheet-list {
  flex: 1;
  padding: 0 18px calc(18px + env(safe-area-inset-bottom));
  max-height: 50vh;
}
.oe__pc {
  display: flex;
  align-items: center;
  gap: 12px;
  border-bottom: 1px solid var(--border);
  padding: 11px 2px;
}
.oe__pc-av {
  width: 40px;
  height: 40px;
  font-size: 16px;
}
.oe__pc-n {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
}
.oe__pc-s {
  font-size: 11.5px;
  color: var(--faint);
  margin-top: 1px;
}

.oe__change {
  margin-right: 12px;
  font-size: 12.5px;
  color: var(--accent);
}

/* 金额区：左「订单编辑」渐变按钮 + 右 总价/额外收入（纯展示） */
.oe__amtarea {
  display: flex;
  gap: 12px;
  align-items: stretch;
  padding: 16px 14px;
}
.oe__editbtn {
  position: relative;
  flex: 0 0 40%;
  display: flex;
  flex-direction: column;
  gap: 8px;
  align-items: center;
  justify-content: center;
  padding: 18px 0;
  background: linear-gradient(150deg, #3ba58c, #0e7c66);
  border-radius: 16px;
  box-shadow: 0 8px 18px rgba(14, 124, 102, 0.28);
  transition: transform 0.1s ease;
}
.oe__editbtn--tap {
  transform: scale(0.97);
}
.oe__editbtn-ic {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
}
.oe__editbtn-t {
  font-size: 15.5px;
  font-weight: 700;
  color: #fff;
}
.oe__editbtn-s {
  margin-top: -2px;
  font-size: 11.5px;
  color: rgba(255, 255, 255, 0.78);
}
.oe__amtcol {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.oe__amtbox {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  background: rgba(14, 124, 102, 0.06);
  border-radius: 14px;
}
.oe__amtbox-lbl {
  font-size: 13px;
  color: var(--muted);
}
.oe__amtbox-r {
  display: flex;
  align-items: baseline;
  gap: 1px;
}
.oe__cur--accent {
  color: var(--accent-text);
}
.oe__amtbox-v {
  font-size: 21px;
  font-weight: 800;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}
.oe__amtbox-v--accent {
  color: var(--accent-text);
}
