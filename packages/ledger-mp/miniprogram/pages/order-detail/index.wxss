.od__edit {
  font-size: 15px;
  font-weight: 600;
  color: var(--accent-text);
}
.od__core {
  display: flex;
  align-items: center;
  gap: 16px;
}
.od__core-r {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.od__core-row {
  display: flex;
  gap: 24px;
}
.od__lbl {
  font-size: 12px;
  color: var(--muted);
  margin-bottom: 2px;
}
.od__val {
  font-size: 14.5px;
  font-weight: 600;
  color: var(--text);
}
.od__val--link {
  color: var(--accent-text);
  margin-right: 4px;
}
.od__t {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 14px;
}
.od__cost {
  display: flex;
  align-items: center;
  gap: 11px;
  margin-bottom: 13px;
}
.od__c-name {
  font-size: 13.5px;
  width: 34px;
  flex-shrink: 0;
}
.od__c-pct {
  font-size: 11.5px;
  color: var(--faint);
  width: 32px;
  text-align: right;
}
.od__c-val {
  font-size: 13.5px;
  font-weight: 600;
  width: 64px;
  text-align: right;
  font-variant-numeric: tabular-nums;
}
.od__ex {
  min-height: 38px;
}
