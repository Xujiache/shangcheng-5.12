.prof {
  min-height: 100vh;
  background: transparent;
}
.prof__user {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: var(--gap);
}
.prof__avatar {
  width: 56px;
  height: 56px;
  font-size: 22px;
}
.prof__name {
  font-size: 18px;
  font-weight: 700;
  color: var(--text);
}
.prof__phone {
  font-size: 13px;
  color: var(--muted);
  margin-top: 3px;
}
.prof__member {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px 18px;
  border-radius: var(--r-card);
  margin-bottom: var(--gap);
  background: linear-gradient(135deg, #2a2f33 0%, #16191c 100%);
  box-shadow: var(--shadow);
}
.prof__member--on {
  background: linear-gradient(135deg, #2b3a36 0%, #1a2420 100%);
  border: 1px solid rgba(244, 213, 138, 0.4);
}
.prof__m-icon {
  width: 38px;
  height: 38px;
  border-radius: 11px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #f4d58a, #d9a441);
  flex-shrink: 0;
}
.prof__m-t {
  font-size: 15px;
  font-weight: 700;
  color: #fff;
}
.prof__m-s {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.62);
  margin-top: 3px;
}
.prof__m-cta {
  font-size: 13px;
  font-weight: 700;
  color: #f4d58a;
  white-space: nowrap;
}
