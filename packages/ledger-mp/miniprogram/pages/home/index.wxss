.home {
  min-height: 100vh;
  background: transparent;
}
.home__hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18px 12px;
  /* 液态玻璃头部（首页自定义头，不走 lz-header）*/
  background: var(--glass-nav-bg);
  -webkit-backdrop-filter: var(--glass-blur-strong);
  backdrop-filter: var(--glass-blur-strong);
}
.home__title {
  font-size: 24px;
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--text);
}
.home__sub {
  font-size: 13px;
  color: var(--muted);
  margin-top: 2px;
}
.home__bell {
  position: relative;
  width: 42px;
  height: 42px;
  border-radius: 999px;
  background: var(--surface);
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-soft);
}
.home__dot {
  position: absolute;
  top: 9px;
  right: 10px;
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: var(--loss);
  border: 1.5px solid var(--surface);
}
.home__hero {
  margin-bottom: var(--gap);
  overflow: hidden;
}
/* 性能模式：跟随手指的流体光晕 */
.home__touch {
  position: absolute;
  width: 240px;
  height: 240px;
  margin-left: -120px;
  margin-top: -120px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(46, 180, 150, 0.4) 0%, rgba(46, 180, 150, 0) 70%);
  pointer-events: none;
  transition: opacity 0.25s ease;
}
.home__hero-label {
  font-size: 13px;
  color: var(--muted);
}
.home__metrics {
  display: flex;
  margin-top: 18px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
}
.home__metric {
  flex: 1;
  text-align: center;
}
.home__m-v {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}
.home__m-l {
  font-size: 11px;
  color: var(--faint);
  margin-top: 3px;
}
.home__goal {
  margin-bottom: var(--gap);
}
.home__goal-t {
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
}
.home__goal-s {
  font-size: 11.5px;
  color: var(--faint);
  margin-top: 9px;
}
.home__card-t {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
}
.home__cost {
  display: flex;
  align-items: center;
  gap: 16px;
}
.home__legend {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 9px;
}
.home__leg {
  display: flex;
  align-items: center;
  gap: 8px;
}
.home__leg-n {
  font-size: 12.5px;
  color: var(--muted);
}
.home__leg-p {
  font-size: 11px;
  color: var(--faint);
  margin-right: 8px;
}
.home__leg-v {
  font-size: 12.5px;
  font-weight: 600;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}
.home__rank {
  width: 22px;
  height: 22px;
  border-radius: 7px;
  background: var(--accent-soft);
  color: var(--accent-text);
  font-size: 12px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.home .lz-card {
  margin-bottom: var(--gap);
}

/* 广告轮播（#2）*/
.home__ads {
  width: 100%;
  height: 130px;
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: var(--gap);
}
.home__ad-img {
  width: 100%;
  height: 130px;
  display: block;
}

/* 工具入口：优化下料（#9）*/
.home__tool {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: var(--gap);
}
.home__tool-icon {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(14, 124, 102, 0.1);
}
.home__tool-t {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
}
.home__tool-s {
  font-size: 12.5px;
  color: var(--muted);
  margin-top: 2px;
}

/* 经营概览面板：周期控件 + 目标行 + 分析分组标题 */
.home__period {
  margin-bottom: 18px;
}
.home__goalrow {
  display: flex;
  align-items: center;
  margin-top: 18px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
}
.home__section {
  font-size: 13px;
  font-weight: 700;
  color: var(--muted);
  letter-spacing: 0.04em;
  margin: 2px 2px 12px;
}
.home__subdiv {
  height: 1px;
  margin-top: 16px;
  background: var(--border);
}

/* 新版本更新日志弹窗 */
.clog-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(8, 20, 16, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32px;
}
.clog-pop {
  width: 100%;
  max-width: 340px;
  background: var(--surface);
  border-radius: 22px;
  padding: 24px 22px 20px;
  box-shadow: 0 20px 60px rgba(8, 24, 18, 0.35);
}
.clog-pop__ver {
  display: inline-block;
  font-size: 12.5px;
  font-weight: 800;
  color: var(--accent-text);
  background: var(--accent-soft);
  padding: 3px 11px;
  border-radius: 999px;
}
.clog-pop__title {
  font-size: 20px;
  font-weight: 800;
  color: var(--text);
  margin-top: 12px;
}
.clog-pop__sub {
  font-size: 12px;
  color: var(--faint);
  margin-top: 4px;
}
.clog-pop__body {
  max-height: 320px;
  margin: 14px 0 18px;
}
.clog-pop__line {
  font-size: 13.5px;
  color: var(--muted);
  line-height: 1.9;
}