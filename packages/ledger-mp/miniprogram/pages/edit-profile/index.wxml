<view class="ep">
  <lz-header title="编辑资料" />

  <view class="lz-page" style="padding-bottom: 40px;">
    <!-- 头像预览 -->
    <view class="ep__avatar-wrap">
      <image
        wx:if="{{avatarUrl}}"
        class="lz-avatar ep__avatar"
        src="{{avatarUrl}}"
        mode="aspectFill"
      />
      <view wx:else class="lz-avatar ep__avatar" style="background: {{hue.grad}};">{{initial}}</view>
      <view class="ep__avatar-tip">{{avatarUrl ? '已设置自定义头像' : '头像取昵称首字 · 可换底色'}}</view>
      <view style="display: flex; gap: 10px; margin-top: 12px;">
        <view class="lz-btn lz-btn--soft lz-btn--sm" hover-class="tap-active" bindtap="onChangeAvatar">
          {{uploading ? '上传中…' : (avatarUrl ? '更换图片' : '上传头像')}}
        </view>
        <view
          wx:if="{{avatarUrl}}"
          class="lz-btn lz-btn--ghost lz-btn--sm"
          hover-class="tap-active"
          bindtap="onUseLetter"
        >
          改回字母
        </view>
      </view>
    </view>

    <!-- 底色选择（仅字母头像时可选） -->
    <view wx:if="{{!avatarUrl}}" class="lz-section-label">头像底色</view>
    <view wx:if="{{!avatarUrl}}" class="ep__swatches">
      <view
        wx:for="{{hues}}"
        wx:key="key"
        class="ep__swatch {{item.key === hueKey ? 'on' : ''}}"
        style="background: {{item.grad}};"
        data-key="{{item.key}}"
        bindtap="onHue"
        hover-class="tap-active"
      >
        <lz-icon wx:if="{{item.key === hueKey}}" name="check" size="18" color="white" stroke="2.4" />
      </view>
    </view>

    <!-- 昵称 -->
    <view class="lz-section-label">昵称</view>
    <view class="lz-field">
      <lz-icon name="user" size="19" color="faint" />
      <input
        class="lz-field__input"
        value="{{nickname}}"
        placeholder="请输入昵称"
        placeholder-class="ph"
        maxlength="20"
        bindinput="onNickname"
      />
    </view>

    <!-- 手机号（只读） -->
    <view class="lz-section-label">登录手机号</view>
    <view class="lz-card lz-card--flush">
      <view class="lz-row lz-row--last">
        <view class="lz-row__icon"><lz-icon name="phone" size="17" color="accent" /></view>
        <view class="lz-row__main">
          <view class="lz-row__label">{{maskedPhone}}</view>
          <view class="lz-row__sub">手机号不可在此修改</view>
        </view>
      </view>
    </view>

    <!-- 微信登录 -->
    <view class="lz-section-label">微信登录</view>
    <view class="lz-card lz-card--flush">
      <view class="lz-row lz-row--last" hover-class="tap-active" bindtap="toWechat">
        <view class="lz-row__icon"><lz-icon name="wechat" size="17" color="accent" /></view>
        <view class="lz-row__main">
          <view class="lz-row__label">绑定微信登录</view>
          <view class="lz-row__sub">绑定后可用微信一键登录</view>
        </view>
        <lz-icon name="chevron" size="16" color="faint" />
      </view>
    </view>
  </view>

  <view class="lz-footer">
    <button class="lz-btn lz-btn--primary lz-btn--lg lz-btn--full {{canSave && !saving ? '' : 'lz-btn--disabled'}}" bindtap="onSave">
      {{saving ? '保存中…' : '保存'}}
    </button>
  </view>
</view>
