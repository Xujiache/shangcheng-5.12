.ep__avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 0 8px;
}
.ep__avatar {
  width: 84px;
  height: 84px;
  font-size: 34px;
}
.ep__avatar-tip {
  font-size: 12px;
  color: var(--faint);
  margin-top: 12px;
}
.ep__swatches {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  padding: 4px 6px 6px;
}
.ep__swatch {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-soft);
  border: 2px solid transparent;
}
.ep__swatch.on {
  border-color: var(--surface);
  box-shadow: 0 0 0 2px var(--accent);
}
.ph {
  color: var(--faint);
}
