<view class="oi">
  <lz-header title="订单编辑" subtitle="门窗报价明细" />

  <view class="oi__body">
    <!-- 新增名称（新项目置顶）-->
    <view class="oi__additem" bindtap="addItem" hover-class="oi__tap">
      <lz-icon name="plus" size="18" color="white" /><text>新增名称</text>
    </view>

    <!-- 产品项 -->
    <view wx:for="{{items}}" wx:key="index" class="oi__item">
      <view class="oi__item-hd">
        <input class="oi__name" value="{{item.name}}" placeholder="名称（如 德曼尼80系统窗）" placeholder-class="ph" maxlength="40" data-idx="{{index}}" data-field="name" bindinput="onItemInput" />
        <view class="oi__item-del" data-idx="{{index}}" bindtap="delItem" hover-class="oi__tap">
          <lz-icon name="trash" size="16" color="#9bab9f" />
        </view>
      </view>

      <view class="oi__subrow">
        <view class="oi__sub-f">
          <text class="oi__sub-l">备注</text>
          <input class="oi__sub-in" value="{{item.note}}" placeholder="如 灰色" placeholder-class="ph" maxlength="30" data-idx="{{index}}" data-field="note" bindinput="onItemInput" />
        </view>
        <view class="oi__sub-f">
          <text class="oi__sub-l">起算面积</text>
          <input class="oi__sub-in oi__sub-in--num" type="digit" value="{{item.baseAreaStr}}" placeholder="0" placeholder-class="ph" data-idx="{{index}}" data-field="baseAreaStr" bindinput="onItemInput" />
          <text class="oi__unit">㎡</text>
        </view>
      </view>

      <!-- 尺寸 -->
      <view wx:for="{{item.sizes}}" wx:for-item="sz" wx:for-index="sidx" wx:key="sidx" class="oi__size">
        <input class="oi__size-in" type="number" value="{{sz.wStr}}" placeholder="宽" placeholder-class="ph" data-idx="{{index}}" data-sidx="{{sidx}}" data-field="wStr" bindinput="onSizeInput" />
        <text class="oi__size-op">×</text>
        <input class="oi__size-in" type="number" value="{{sz.hStr}}" placeholder="高" placeholder-class="ph" data-idx="{{index}}" data-sidx="{{sidx}}" data-field="hStr" bindinput="onSizeInput" />
        <text class="oi__size-eq">={{sz.areaText || '0'}}㎡</text>
        <input class="oi__size-note" value="{{sz.note}}" placeholder="备注" placeholder-class="ph" maxlength="30" data-idx="{{index}}" data-sidx="{{sidx}}" data-field="note" bindinput="onSizeInput" />
        <view class="oi__size-del" data-idx="{{index}}" data-sidx="{{sidx}}" bindtap="delSize" hover-class="oi__tap">
          <lz-icon name="close" size="13" color="#9bab9f" stroke="2.2" />
        </view>
      </view>
      <view class="oi__addsize" data-idx="{{index}}" bindtap="addSize" hover-class="oi__tap">
        <lz-icon name="plus" size="13" color="#2E9E78" stroke="2.2" /><text>新增尺寸</text>
      </view>

      <!-- 数量/面积 × 单价 = 小计 -->
      <view class="oi__qtyrow">
        <text class="oi__qty-l">数量/面积</text>
        <text wx:if="{{item.hasSizes}}" class="oi__qty-auto">{{item.qtyAutoText}}</text>
        <input wx:else class="oi__qty-in" type="digit" value="{{item.qtyStr}}" placeholder="0" placeholder-class="ph" data-idx="{{index}}" data-field="qtyStr" bindinput="onItemInput" />
        <text class="oi__qty-op">× 单价</text>
        <input class="oi__price-in" type="digit" value="{{item.unitPriceStr}}" placeholder="0" placeholder-class="ph" data-idx="{{index}}" data-field="unitPriceStr" bindinput="onItemInput" />
        <text class="oi__qty-op">=</text>
        <text class="oi__subtotal">{{item.subtotalText}}</text>
      </view>
    </view>

    <view wx:if="{{!items.length}}" class="oi__empty">点上方「新增名称」开始录入门窗明细</view>

    <!-- 金额汇总 -->
    <view class="oi__card oi__totals">
      <view class="oi__t-row">
        <text class="oi__t-l">金额</text>
        <text class="oi__t-v">{{amountText}}</text>
      </view>
      <view class="oi__t-row">
        <text class="oi__t-l">优惠</text>
        <view class="oi__t-input"><text class="oi__cur">¥</text><input type="digit" value="{{discountStr}}" placeholder="0" placeholder-class="ph" bindinput="onDiscount" /></view>
      </view>
      <view class="oi__t-row oi__t-row--main">
        <text class="oi__t-l">总价</text>
        <text class="oi__t-v oi__t-v--main">{{totalText}}</text>
      </view>
      <view class="oi__t-row">
        <text class="oi__t-l">额外收入</text>
        <view class="oi__t-input"><text class="oi__cur">¥</text><input type="digit" value="{{extraIncomeStr}}" placeholder="0" placeholder-class="ph" bindinput="onExtra" /></view>
      </view>
      <view class="oi__t-row">
        <text class="oi__t-l">定金</text>
        <view class="oi__t-input"><text class="oi__cur">¥</text><input type="digit" value="{{depositStr}}" placeholder="0" placeholder-class="ph" bindinput="onDeposit" /></view>
      </view>
      <view class="oi__t-row oi__t-row--last">
        <text class="oi__t-l">未收</text>
        <text class="oi__t-v">{{unpaidText}}</text>
      </view>
    </view>

    <!-- 订单备注 -->
    <view class="oi__card">
      <view class="oi__note-l">订单备注</view>
      <textarea class="oi__note" value="{{note}}" placeholder="整单说明（选填）" placeholder-class="ph" maxlength="200" auto-height bindinput="onNote" />
    </view>
  </view>

  <view class="oi__bar">
    <button class="oi__save" bindtap="save">保存</button>
    <text class="oi__bar-hint">已编辑内容退出自动保存</text>
  </view>
</view>
