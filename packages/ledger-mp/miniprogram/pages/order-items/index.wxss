/* 订单编辑 · 门窗报价明细 · Mint Airy */
page {
  background: #e9f2ed;
}
.oi {
  min-height: 100vh;
  color: #19271f;
  font-family:
    -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei',
    'Segoe UI', system-ui, sans-serif;
}
.oi__body {
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 8px 16px 120px;
}
.oi__tap {
  opacity: 0.62;
}
.ph {
  color: #9bab9f;
}

/* 新增名称按钮 */
.oi__additem {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  height: 46px;
  border-radius: 16px;
  background: #2e9e78;
  color: #fff;
  font-size: 15px;
  font-weight: 700;
  box-shadow: 0 8px 20px rgba(46, 158, 120, 0.25);
}

/* 产品项白卡 */
.oi__item {
  background: #fff;
  border-radius: 22px;
  box-shadow:
    0 8px 28px rgba(31, 107, 92, 0.09),
    0 1.5px 4px rgba(20, 40, 33, 0.04);
  padding: 14px 16px;
}
.oi__item-hd {
  display: flex;
  align-items: center;
  gap: 8px;
}
.oi__name {
  flex: 1;
  min-width: 0;
  font-size: 15.5px;
  font-weight: 800;
  color: #19271f;
}
.oi__item-del {
  width: 28px;
  height: 28px;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.oi__subrow {
  display: flex;
  gap: 10px;
  margin-top: 8px;
  padding-bottom: 12px;
  border-bottom: 1px solid rgba(31, 107, 92, 0.1);
}
.oi__sub-f {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 6px;
  background: #f3f8f5;
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 8px 12px;
}
.oi__sub-l {
  font-size: 12px;
  color: #6c7d75;
  flex: 0 0 auto;
}
.oi__sub-in {
  flex: 1;
  min-width: 0;
  font-size: 14px;
  font-weight: 600;
  color: #19271f;
}
.oi__sub-in--num {
  text-align: right;
}
.oi__unit {
  font-size: 12px;
  color: #9bab9f;
  flex: 0 0 auto;
}

/* 尺寸块（每条尺寸可挂任意多条备注，浅底分组）*/
.oi__size {
  margin-top: 12px;
  padding: 10px;
  border-radius: 14px;
  background: #f5faf7;
  border: 1px solid rgba(31, 107, 92, 0.08);
}
.oi__size-row {
  display: flex;
  align-items: flex-start;
  gap: 6px;
}
.oi__size-fields {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 7px 5px;
}
.oi__size-in {
  flex: 0 0 auto;
  width: 52px;
  box-sizing: border-box;
  height: 38px;
  line-height: 1.4;
  text-align: center;
  font-size: 14px;
  font-weight: 700;
  color: #19271f;
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0;
}
/* 尺寸件数输入框（窄）：宽×高×件数 */
.oi__size-cnt {
  flex: 0 0 auto;
  width: 46px;
  box-sizing: border-box;
  height: 38px;
  line-height: 1.4;
  text-align: center;
  font-size: 14px;
  font-weight: 700;
  color: #19271f;
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0;
}
.oi__size-op {
  font-size: 13px;
  color: #9bab9f;
  flex: 0 0 auto;
}
.oi__size-mm {
  font-size: 11.5px;
  color: #9bab9f;
  flex: 0 0 auto;
}
.oi__size-eq {
  flex: 0 0 auto;
  font-size: 13px;
  font-weight: 700;
  color: #2e9e78;
}
.oi__size-del {
  width: 28px;
  height: 28px;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
}
/* 备注：紧跟「=面积」之后的内联小框（可删），多条自动换行；「+备注」同排 */
.oi__notechip {
  display: flex;
  flex: 1 1 64px;
  min-width: 56px;
  max-width: 150px;
  align-items: center;
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 9px;
  padding-left: 8px;
  height: 32px;
}
.oi__notechip-in {
  flex: 1;
  min-width: 0;
  font-size: 13px;
  color: #19271f;
}
.oi__notechip-del {
  width: 22px;
  height: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.oi__addnote {
  display: inline-flex;
  align-items: center;
  gap: 2px;
  padding: 7px 9px;
  border-radius: 8px;
  background: rgba(46, 158, 120, 0.08);
  font-size: 12px;
  font-weight: 700;
  color: #2e9e78;
}
.oi__addsize {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  margin-top: 12px;
  padding: 7px 13px;
  border-radius: 11px;
  background: rgba(46, 158, 120, 0.09);
  font-size: 13px;
  font-weight: 700;
  color: #2e9e78;
}

/* 数量/面积 × 单价（小计另起一行） */
.oi__qtyrow {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid rgba(31, 107, 92, 0.1);
}
.oi__qty-l {
  font-size: 12.5px;
  color: #6c7d75;
  flex: 0 0 auto;
}
.oi__qty-auto {
  font-size: 15px;
  font-weight: 800;
  color: #19271f;
  flex: 0 0 auto;
}
/* 小计：单独一行，与上一行解耦，金额不再被挤出截断 */
.oi__subrow2 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8px;
}
.oi__sub2-l {
  font-size: 12.5px;
  color: #6c7d75;
}
.oi__qty-in {
  width: 56px;
  box-sizing: border-box;
  height: 40px;
  line-height: 1.4;
  font-size: 15px;
  font-weight: 700;
  color: #19271f;
  background: #f3f8f5;
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0 8px;
  text-align: center;
}
.oi__qty-op {
  font-size: 12.5px;
  color: #9bab9f;
  flex: 0 0 auto;
}
.oi__price-in {
  width: 68px;
  box-sizing: border-box;
  height: 40px;
  line-height: 1.4;
  font-size: 15px;
  font-weight: 700;
  color: #19271f;
  background: #f3f8f5;
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0 8px;
  text-align: center;
}
/* 小计：可手动改写的输入框（占位显示自动算的值，清空即回落自动） */
.oi__sub2-box {
  display: flex;
  align-items: center;
  gap: 2px;
  background: #f3f8f5;
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 7px 12px;
}
.oi__sub2-box .oi__cur {
  font-size: 15px;
  font-weight: 800;
  color: #2e9e78;
}
.oi__sub2-in {
  width: 100px;
  box-sizing: border-box;
  height: 40px;
  line-height: 1.4;
  text-align: right;
  font-size: 17px;
  font-weight: 800;
  color: #2e9e78;
}
.oi__sub2-hint {
  margin-top: 6px;
  text-align: right;
  font-size: 11px;
  color: #9bab9f;
}

.oi__empty {
  text-align: center;
  color: #9bab9f;
  font-size: 13.5px;
  padding: 10px 0;
}

/* 白卡 */
.oi__card {
  background: #fff;
  border-radius: 22px;
  box-shadow:
    0 8px 28px rgba(31, 107, 92, 0.09),
    0 1.5px 4px rgba(20, 40, 33, 0.04);
  padding: 4px 18px;
}

/* 金额汇总 */
.oi__t-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 13px 0;
  border-bottom: 1px solid rgba(31, 107, 92, 0.1);
}
.oi__t-row--last {
  border-bottom: none;
}
.oi__t-l {
  font-size: 14.5px;
  font-weight: 600;
  color: #6c7d75;
}
.oi__t-v {
  font-size: 16px;
  font-weight: 700;
  color: #19271f;
}
.oi__t-row--main .oi__t-l {
  color: #19271f;
  font-weight: 800;
}
.oi__t-v--main {
  font-size: 22px;
  font-weight: 800;
  color: #2e9e78;
}
/* 优惠/定金/收款：做成可见的输入框（浅底+圆角+足够高），与明细输入框统一观感 */
.oi__t-input {
  display: flex;
  align-items: center;
  gap: 2px;
  background: #f3f8f5;
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 8px 12px;
}
.oi__cur {
  font-size: 13px;
  font-weight: 700;
  color: #6c7d75;
}
.oi__t-input input {
  width: 96px;
  text-align: right;
  font-size: 16px;
  font-weight: 700;
  color: #19271f;
}
/* 定金超过总价的弱警示 */
.oi__t-warn {
  padding: 0 0 12px;
  margin-top: -6px;
  font-size: 11.5px;
  color: var(--loss);
  text-align: right;
}

/* 订单备注 */
.oi__note-l {
  font-size: 13px;
  font-weight: 600;
  color: #6c7d75;
  padding: 14px 0 4px;
}
.oi__note {
  width: 100%;
  min-height: 40px;
  padding-bottom: 14px;
  font-size: 14px;
  line-height: 1.5;
  color: #19271f;
}

/* 固定保存栏 */
.oi__bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 10px 16px calc(8px + env(safe-area-inset-bottom));
  background: #e9f2ed;
  border-top: 1px solid rgba(31, 107, 92, 0.1);
}
.oi__save {
  width: 100%;
  height: 50px;
  border: none;
  border-radius: 16px;
  background: #2e9e78;
  color: #fff;
  font-size: 16px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 20px rgba(46, 158, 120, 0.25);
}
.oi__save::after {
  border: none;
}
.oi__bar-hint {
  font-size: 11px;
  color: #9bab9f;
}
