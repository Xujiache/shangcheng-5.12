.cd__edit {
  font-size: 15px;
  font-weight: 600;
  color: var(--accent-text);
}
.cd__contact {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: var(--gap);
}
.cd__av {
  width: 56px;
  height: 56px;
  font-size: 22px;
}
.cd__name {
  font-size: 19px;
  font-weight: 700;
  color: var(--text);
}
.cd__phone {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 13px;
  color: var(--accent-text);
  margin-top: 4px;
}
.cd__addr {
  font-size: 12.5px;
  color: var(--muted);
  margin-top: 4px;
}
.cd__stats {
  display: flex;
  margin-bottom: var(--gap);
}
.cd__stat {
  flex: 1;
  text-align: center;
}
.cd__stat-v {
  font-size: 18px;
  font-weight: 700;
  color: var(--text);
}
.cd__stat-l {
  font-size: 11.5px;
  color: var(--faint);
  margin-top: 4px;
}
.cd__note {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: var(--gap);
}
.cd__note text {
  font-size: 13px;
  color: var(--muted);
}
