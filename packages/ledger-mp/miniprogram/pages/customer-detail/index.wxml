<view class="cd">
  <lz-header title="客户详情">
    <view slot="right" class="cd__edit" bindtap="toEdit">编辑</view>
  </lz-header>

  <view wx:if="{{c}}" class="lz-page" style="padding-bottom: 110px;">
    <!-- 联系卡 -->
    <view class="lz-card lz-card--glow cd__contact">
      <view class="lz-avatar cd__av">{{initial}}</view>
      <view class="lz-flex1" style="min-width: 0;">
        <view class="cd__name">{{c.name}}</view>
        <view wx:if="{{c.phone}}" class="cd__phone" bindtap="callPhone">
          <lz-icon name="phone" size="13" color="accent" /><text>{{c.phone}}</text>
        </view>
        <view wx:if="{{c.address}}" class="cd__addr">{{c.address}}</view>
      </view>
    </view>

    <!-- 统计 -->
    <view class="lz-card cd__stats">
      <view class="cd__stat">
        <view class="lz-money lz-money--accent" style="font-size: 22px;">{{profitText}}</view>
        <view class="cd__stat-l">累计利润</view>
      </view>
      <view class="cd__stat">
        <view class="cd__stat-v">{{c.count}}</view>
        <view class="cd__stat-l">订单数</view>
      </view>
      <view class="cd__stat">
        <view class="cd__stat-v">{{marginPct}}%</view>
        <view class="cd__stat-l">利润率</view>
      </view>
    </view>

    <view wx:if="{{c.note}}" class="lz-card cd__note">
      <lz-icon name="tag" size="15" color="faint" /><text>{{c.note}}</text>
    </view>

    <!-- 历史订单 -->
    <view class="lz-section-label">历史订单（{{c.count}}）</view>
    <view wx:if="{{orders.length}}" class="lz-card lz-card--flush">
      <view wx:for="{{orders}}" wx:key="id" class="lz-row" data-id="{{item.id}}" bindtap="toOrder" hover-class="tap-active">
        <view class="lz-row__main">
          <view class="lz-row__label" style="font-size: 14px;">{{item.date}}</view>
          <view class="lz-row__sub">总价 {{item.totalText}}</view>
        </view>
        <view class="lz-money lz-money--accent" style="font-size: 14.5px;">{{item.profitText}}</view>
        <lz-icon name="chevron" size="15" color="faint" style="margin-left: 6px;" />
      </view>
    </view>
    <view wx:else class="lz-empty">暂无订单</view>
  </view>

  <view wx:if="{{c}}" class="lz-footer" style="display: flex; gap: 10px;">
    <button class="lz-btn lz-btn--ghost lz-btn--lg lz-flex1" bindtap="callPhone" wx:if="{{c.phone}}">
      <lz-icon name="phone" size="18" color="text" /> 联系
    </button>
    <button class="lz-btn lz-btn--primary lz-btn--lg lz-flex1" bindtap="reorder">
      <lz-icon name="plus" size="18" color="white" /> 再来一单
    </button>
  </view>
</view>
