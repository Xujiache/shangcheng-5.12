.login {
  min-height: 100vh;
  padding: 0 28px;
  display: flex;
  flex-direction: column;
  background-image: var(--bg-grad);
}
.login__brand {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.login__logo {
  width: 76px;
  height: 76px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #3ba58c, var(--accent));
  box-shadow: 0 16px 36px rgba(14, 124, 102, 0.3), inset 0 1px 1px rgba(255, 255, 255, 0.35);
}
.login__name {
  font-size: 30px;
  font-weight: 800;
  letter-spacing: -0.02em;
  margin-top: 22px;
  color: var(--text);
}
.login__slogan {
  font-size: 15px;
  color: var(--muted);
  margin-top: 8px;
}
.login__form {
  margin-top: 34px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.ph {
  color: var(--faint);
}
.login__getcode {
  font-size: 13.5px;
  font-weight: 600;
  color: var(--faint);
  white-space: nowrap;
  flex-shrink: 0;
}
.login__getcode.on {
  color: var(--accent-text);
}
.login__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 4px;
}
.login__remember {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12.5px;
  color: var(--muted);
}
.login__forgot {
  font-size: 12.5px;
  color: var(--accent-text);
}
.login__divider {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 6px 0 2px;
}
.login__line {
  flex: 1;
  height: 1px;
  background: var(--border);
}
.login__divider text {
  font-size: 11.5px;
  color: var(--faint);
}
.login__agreement {
  margin-top: auto;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 6px;
  font-size: 11.5px;
  color: var(--faint);
  padding: 20px 24px 30px;
  line-height: 1.4;
}
.login__agreebox {
  flex: 0 0 auto;
  width: 16px;
  height: 16px;
  margin-top: 1px;
  border-radius: 5px;
  border: 1.5px solid var(--line, #d2dad6);
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.login__agreebox.on {
  border-color: var(--accent);
  background: var(--accent);
}
.login__agreetxt {
  flex: 1;
  text-align: left;
  max-width: 280px;
}
.login__link {
  color: var(--accent-text);
}
.login__register {
  text-align: center;
  margin-top: 18px;
  font-size: 13.5px;
  color: var(--muted);
}
