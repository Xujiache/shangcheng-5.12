<view class="login">
  <view style="height: calc(env(safe-area-inset-top) + 50px);"></view>

  <!-- 品牌 -->
  <view class="login__brand">
    <view class="login__logo">
      <lz-icon name="cube" size="40" color="white" stroke="2" />
    </view>
    <view class="login__name">门窗利账</view>
    <view class="login__slogan">登录后管理订单与利润</view>
  </view>

  <!-- 静默登录校验中：显示占位，不露出表单（避免每次启动闪登录页） -->
  <view
    wx:if="{{checking}}"
    class="login__checking"
    style="display: flex; justify-content: center; padding: 64px 0;"
  >
    <text style="color: var(--muted); font-size: 15px;">正在进入…</text>
  </view>

  <!-- 表单 -->
  <view wx:else class="login__form">
    <view style="width: 200px;">
      <lz-segmented options="{{modes}}" value="{{mode}}" bindchange="onModeChange" />
    </view>

    <view class="lz-field">
      <lz-icon name="phone" size="19" color="faint" />
      <input
        class="lz-field__input"
        value="{{phone}}"
        type="number"
        placeholder="请输入手机号"
        placeholder-class="ph"
        bindinput="onPhone"
      />
    </view>

    <view wx:if="{{mode === 'password'}}" class="lz-field">
      <lz-icon name="lock" size="19" color="faint" />
      <input
        class="lz-field__input"
        value="{{pwd}}"
        password="{{!showPwd}}"
        placeholder="请输入密码（至少 6 位）"
        placeholder-class="ph"
        bindinput="onPwd"
      />
      <view hover-class="tap-active" bindtap="togglePwd" style="padding: 4px;">
        <lz-icon name="{{showPwd ? 'eye' : 'eyeoff'}}" size="19" color="faint" />
      </view>
    </view>

    <view wx:else class="lz-field">
      <lz-icon name="message" size="19" color="faint" />
      <input
        class="lz-field__input"
        value="{{code}}"
        type="number"
        placeholder="6 位短信验证码"
        placeholder-class="ph"
        bindinput="onCode"
      />
      <view class="login__getcode {{phone.length === 11 && sent === 0 ? 'on' : ''}}" bindtap="getCode">
        {{sent > 0 ? sent + 's' : '获取验证码'}}
      </view>
    </view>

    <view class="login__row">
      <view class="login__remember">
        <lz-icon name="check" size="13" color="accent" />
        <text>记住登录</text>
      </view>
      <text class="login__forgot" bindtap="onForgot">忘记密码？</text>
    </view>

    <button class="lz-btn lz-btn--primary lz-btn--lg lz-btn--full {{canLogin ? '' : 'lz-btn--disabled'}}" bindtap="doLogin">
      {{loading ? '登录中…' : '登录'}}
    </button>

    <view class="login__divider">
      <view class="login__line"></view>
      <text>其他方式</text>
      <view class="login__line"></view>
    </view>
    <button class="lz-btn lz-btn--ghost lz-btn--full" bindtap="onWechat">
      <lz-icon name="wechat" size="20" color="#07C160" stroke="1.9" />
      <text>微信登录</text>
    </button>

    <view wx:if="{{allowRegister}}" class="login__register" bindtap="toRegister">
      还没有账号？<text class="login__link">立即注册</text>
    </view>
  </view>

  <view wx:if="{{!checking}}" class="login__agreement" bindtap="toggleAgree">
    <view class="login__agreebox {{agreed ? 'on' : ''}}">
      <lz-icon wx:if="{{agreed}}" name="check" size="12" color="white" stroke="2.5" />
    </view>
    <view class="login__agreetxt">
      已阅读并同意
      <text class="login__link" catchtap="onDoc" data-key="terms">《用户协议》</text>
      与
      <text class="login__link" catchtap="onDoc" data-key="privacy">《隐私政策》</text>
    </view>
  </view>
</view>
