.ord {
  min-height: 100vh;
  background-image: var(--bg-grad);
}
.ord__hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18px 12px;
}
.ord__title {
  font-size: 24px;
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--text);
}
.ord__cust-btn {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 7px 13px;
  border-radius: 999px;
  background: var(--surface);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-soft);
  font-size: 13.5px;
  font-weight: 600;
  color: var(--accent-text);
}
.ord__sum {
  display: flex;
  margin-bottom: var(--gap);
}
.ord__sum-i {
  flex: 1;
  text-align: center;
}
.ord__sum-v {
  font-size: 17px;
  font-weight: 800;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}
.ord__sum-l {
  font-size: 11.5px;
  color: var(--faint);
  margin-top: 4px;
}
.ord__tools {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: var(--gap);
}
.ord__search {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8px;
  height: 40px;
  padding: 0 12px;
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: 12px;
}
.ord__search-in {
  flex: 1;
  font-size: 14.5px;
  color: var(--text);
}
.ph {
  color: var(--faint);
}
.ord__item {
  margin-bottom: 12px;
}
.ord__cust {
  font-size: 16px;
  font-weight: 700;
  color: var(--text);
  margin-right: 10px;
}
.ord__meta {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 7px;
  font-size: 12px;
  color: var(--muted);
}
.ord__dot {
  color: var(--faint);
}
.ord__bar {
  display: flex;
  height: 6px;
  border-radius: 999px;
  overflow: hidden;
  margin-top: 12px;
  background: var(--track);
}
.ord__seg {
  height: 100%;
}
.ord__foot {
  text-align: center;
  font-size: 12px;
  color: var(--faint);
  padding: 4px 0 10px;
}
