.ord {
  min-height: 100vh;
  background: transparent;
}
.ord__hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18px 12px;
}
.ord__title {
  font-size: 24px;
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--text);
}
.ord__cust-btn {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 7px 13px;
  border-radius: 999px;
  background: var(--surface);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-soft);
  font-size: 13.5px;
  font-weight: 600;
  color: var(--accent-text);
}
.ord__sum {
  display: flex;
  margin-bottom: var(--gap);
}
.ord__sum-i {
  flex: 1;
  text-align: center;
}
.ord__sum-v {
  font-size: 17px;
  font-weight: 800;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}
.ord__sum-l {
  font-size: 11.5px;
  color: var(--faint);
  margin-top: 4px;
}
.ord__tools {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: var(--gap);
}
.ord__search {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8px;
  height: 40px;
  padding: 0 12px;
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: 12px;
}
.ord__search-in {
  flex: 1;
  font-size: 14.5px;
  color: var(--text);
}
/* 清空按钮：图标小、热区大（户外/戴手套也好点） */
.ord__search-clear {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 6px 12px 12px;
  margin-right: -6px;
}
.ph {
  color: var(--faint);
}
.ord__item {
  margin-bottom: 12px;
}
.ord__cust {
  font-size: 16px;
  font-weight: 700;
  color: var(--text);
  margin-right: 10px;
}
.ord__meta {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 7px;
  font-size: 12px;
  color: var(--muted);
}
.ord__dot {
  color: var(--faint);
}
.ord__bar {
  display: flex;
  height: 6px;
  border-radius: 999px;
  overflow: hidden;
  margin-top: 14px;
  background: var(--track);
}
.ord__seg {
  height: 100%;
}
.ord__foot {
  text-align: center;
  font-size: 12px;
  color: var(--faint);
  padding: 4px 0 10px;
}

/* 订单卡重构：首字母徽标 + 标注利润 + 统计行 */
.ord__row {
  display: flex;
  align-items: center;
  gap: 12px;
}
.ord__avatar {
  flex-shrink: 0;
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--accent-soft);
  color: var(--accent-text);
  font-size: 17px;
  font-weight: 800;
}
.ord__date {
  font-size: 12px;
  color: var(--faint);
  margin-top: 3px;
}
.ord__profit {
  flex-shrink: 0;
  text-align: right;
}
.ord__profit-l {
  font-size: 11px;
  color: var(--faint);
}
.ord__profit-v {
  font-size: 19px;
  margin-top: 1px;
}
.ord__stats {
  display: flex;
  gap: 28px;
  margin-top: 14px;
  padding-top: 12px;
  border-top: 1px solid var(--border);
}
.ord__stat {
  display: flex;
  align-items: baseline;
  gap: 6px;
}
.ord__stat-l {
  font-size: 12px;
  color: var(--muted);
}
.ord__stat-v {
  font-size: 14px;
  font-weight: 700;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}
.ord__rate {
  color: var(--accent-text);
}
