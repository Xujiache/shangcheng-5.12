.cut__lbl {
  font-size: 14px;
  color: var(--muted);
}
.cut__in {
  flex: 1;
  text-align: right;
  font-size: 15px;
  color: var(--text);
}
.cut__in--seg {
  flex: 0 0 120px;
  text-align: left;
}
.cut__in--qty {
  flex: 0 0 90px;
  text-align: left;
}
.cut__sec-t {
  font-size: 13px;
  color: var(--muted);
  font-weight: 700;
}
.cut__add {
  display: flex;
  align-items: center;
  gap: 3px;
  color: var(--accent);
  font-size: 13px;
}
.cut__del {
  padding: 4px;
}
.cut__metrics {
  display: flex;
}
.cut__m {
  flex: 1;
  text-align: center;
}
.cut__m-v {
  font-size: 20px;
  font-weight: 800;
  color: var(--accent-text);
}
.cut__m-l {
  font-size: 11px;
  color: var(--muted);
  margin-top: 2px;
}
.cut__bar {
  padding: 10px 14px;
  border-top: 1rpx solid rgba(20, 32, 28, 0.06);
}
.cut__bar-h {
  font-size: 12.5px;
  color: var(--muted);
  margin-bottom: 4px;
}
.cut__bar-c {
  font-size: 14px;
  color: var(--text);
  font-weight: 600;
}
