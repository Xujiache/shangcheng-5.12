.cut__lbl {
  font-size: 14px;
  color: var(--muted);
}
.cut__in {
  flex: 1;
  text-align: right;
  font-size: 15px;
  color: var(--text);
}
.cut__in--seg {
  flex: 1 1 0;
  min-width: 0;
  text-align: left;
}
.cut__in--qty {
  flex: 0 1 80px;
  min-width: 0;
  text-align: left;
}
.cut__in--dim {
  flex: 1 1 0;
  min-width: 0;
  text-align: left;
}
.cut__in--qty2 {
  flex: 0 1 58px;
  min-width: 0;
  text-align: left;
}
/* 清单行 × 分隔符（不挤压、不换行）*/
.cut__x {
  flex: 0 0 auto;
  margin: 0 6px;
}
.cut__hist {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  font-size: 13.5px;
  font-weight: 700;
  color: var(--accent);
}
.cut__sec-t {
  font-size: 13px;
  color: var(--muted);
  font-weight: 700;
}
.cut__hd-acts {
  display: flex;
  align-items: center;
  gap: 16px;
}
.cut__clear {
  display: flex;
  align-items: center;
  gap: 3px;
  color: var(--muted);
  font-size: 13px;
}
.cut__add {
  display: flex;
  align-items: center;
  gap: 3px;
  color: var(--accent);
  font-size: 13px;
}
.cut__del {
  flex: 0 0 auto;
  padding: 4px 2px;
  margin-left: 2px;
}
.cut__metrics {
  display: flex;
}
.cut__m {
  flex: 1;
  text-align: center;
}
.cut__m-v {
  font-size: 20px;
  font-weight: 800;
  color: var(--accent-text);
}
.cut__m-l {
  font-size: 11px;
  color: var(--muted);
  margin-top: 2px;
}
.cut__bar {
  padding: 10px 14px;
  border-top: 1rpx solid rgba(20, 32, 28, 0.06);
}
.cut__bar-h {
  font-size: 12.5px;
  color: var(--muted);
  margin-bottom: 4px;
}
.cut__bar-c {
  font-size: 14px;
  color: var(--text);
  font-weight: 600;
}
/* 继续编辑提示条 */
.cut__editing {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-top: var(--gap);
  padding: 10px 14px;
  border-radius: 12px;
  background: rgba(46, 158, 120, 0.08);
}
.cut__editing-t {
  flex: 1;
  min-width: 0;
  font-size: 12.5px;
  color: var(--muted);
}
.cut__editing-new {
  flex: 0 0 auto;
  font-size: 13px;
  font-weight: 700;
  color: var(--accent);
}

/* 排料图画布 */
.cut__cvwrap {
  padding: 6px 8px 12px;
}
.cut__cv {
  width: 100%;
  display: block;
}
/* 导出专用画布：移出可视区但仍渲染（display:none 会导致截图空白）*/
.cut__cv-export {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 500px;
  height: 400px;
}

/* 导出 / 保存方案按钮组 */
.cut__acts {
  display: flex;
  gap: 12px;
  margin-top: 16px;
}
.cut__act {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

/* ── 历史方案底部面板（镜像 order-edit 客户选择器）── */
.oe__mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  background: rgba(20, 30, 25, 0.32);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.oe__sheet {
  background: #fff;
  border-radius: 24px 24px 0 0;
  padding: 8px 18px calc(20px + env(safe-area-inset-bottom));
  max-height: 82vh;
  display: flex;
  flex-direction: column;
}
.oe__sheet-handle {
  width: 38px;
  height: 4.5px;
  border-radius: 999px;
  background: rgba(31, 107, 92, 0.12);
  margin: 0 auto 14px;
}
.oe__sheet-hd {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}
.oe__sheet-t {
  font-size: 17px;
  font-weight: 800;
  color: #19271f;
}
.oe__sheet-list {
  max-height: 60vh;
}
.oe__empty {
  text-align: center;
  font-size: 13px;
  color: #9bab9f;
  padding: 28px 0;
}
.cut__hclose {
  font-size: 13.5px;
  font-weight: 700;
  color: var(--muted);
}
.cut__hrow {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 0;
  border-bottom: 1px solid rgba(31, 107, 92, 0.1);
}
.cut__hrow-t {
  font-size: 15px;
  font-weight: 700;
  color: #19271f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cut__hrow-s {
  font-size: 12.5px;
  color: var(--muted);
  margin-top: 3px;
}
.cut__hrow-d {
  font-size: 11.5px;
  color: #9bab9f;
  margin-top: 2px;
}
.cut__hdel {
  flex: 0 0 auto;
  padding: 6px;
}
.cut__herr {
  text-align: center;
  font-size: 13px;
  color: var(--muted);
  padding: 24px 0;
}
.cut__hretry {
  margin-top: 10px;
  display: inline-block;
  font-size: 13.5px;
  font-weight: 700;
  color: var(--accent);
}
