.ms__body {
  padding-bottom: 120px;
}
.ms__logout {
  font-size: 14px;
  color: var(--muted);
}
/* hero */
.ms__hero {
  position: relative;
  border-radius: var(--r-card);
  overflow: hidden;
  padding: 20px;
  background: linear-gradient(135deg, #2a2f33 0%, #16191c 100%);
  box-shadow: var(--shadow);
}
.ms__hero--on {
  background: linear-gradient(135deg, #1b5e4f 0%, #0e3b31 100%);
}
.ms__hero-top {
  display: flex;
  align-items: center;
  gap: 11px;
}
.ms__crown {
  width: 38px;
  height: 38px;
  border-radius: 11px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #f4d58a, #d9a441);
}
.ms__plan {
  font-size: 16px;
  font-weight: 700;
  color: #fff;
}
.ms__status {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.66);
  margin-top: 2px;
}
.ms__days {
  text-align: right;
}
.ms__days-n {
  font-size: 26px;
  font-weight: 800;
  color: #fff;
  line-height: 1;
}
.ms__days-l {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.66);
  margin-top: 3px;
}
.ms__hero-bot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18px;
  padding-top: 14px;
  border-top: 1px solid rgba(255, 255, 255, 0.12);
}
.ms__valid {
  font-size: 12.5px;
  color: rgba(255, 255, 255, 0.7);
}
.ms__badge {
  font-size: 11px;
  font-weight: 700;
  padding: 3px 9px;
  border-radius: 999px;
}
.ms__badge--soon {
  color: #f4d58a;
  background: rgba(244, 213, 138, 0.16);
}
.ms__badge--lock {
  color: #f0a090;
  background: rgba(240, 160, 144, 0.16);
}
/* notice */
.ms__notice {
  display: flex;
  align-items: flex-start;
  gap: 9px;
  margin-top: var(--gap);
  padding: 12px 14px;
  border-radius: var(--r-btn);
  background: rgba(200, 68, 43, 0.08);
  border: 1px solid rgba(200, 68, 43, 0.22);
}
.ms__notice text {
  font-size: 12.5px;
  color: var(--muted);
  line-height: 1.5;
}
/* plans */
.ms__plans {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.ms__plan-card {
  flex: 1;
  min-width: 28%;
  border: 1.5px solid var(--border);
  background: var(--surface);
  border-radius: var(--r-card);
  padding: 14px 8px 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  box-shadow: var(--shadow-soft);
}
.ms__plan-card.on {
  border-color: var(--accent);
  background: var(--accent-soft);
}
.ms__pc-label {
  font-size: 14px;
  font-weight: 700;
  color: var(--text);
}
.ms__pc-price {
  font-size: 18px;
  font-weight: 800;
  color: var(--accent-text);
}
.ms__pc-days {
  font-size: 11px;
  color: var(--faint);
}
.ms__foot-note {
  font-size: 11.5px;
  color: var(--faint);
  text-align: center;
  padding: 14px 10px 4px;
  line-height: 1.6;
}
