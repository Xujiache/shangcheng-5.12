/* 自定义开关（48x29 胶囊，开启时主色） */
.tg {
  width: 48px;
  height: 29px;
  border-radius: 999px;
  background: var(--track);
  flex-shrink: 0;
  position: relative;
  transition: background 0.2s ease;
}
.tg--on {
  background: var(--accent);
}
.tg__knob {
  position: absolute;
  top: 2.5px;
  left: 2.5px;
  width: 24px;
  height: 24px;
  border-radius: 999px;
  background: #fff;
  box-shadow: 0 1px 3px rgba(16, 40, 30, 0.25);
  transition: transform 0.2s ease;
}
.tg--on .tg__knob {
  transform: translateX(19px);
}
.pv__note {
  font-size: 12px;
  color: var(--faint);
  line-height: 1.6;
  padding: 14px 8px 4px;
}

/* 数据导出/导入弹窗 */
.ph {
  color: var(--faint);
}
.dm-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(8, 20, 16, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32px;
}
.dm-pop {
  width: 100%;
  max-width: 340px;
  background: var(--surface);
  border-radius: 22px;
  padding: 22px;
  box-shadow: 0 20px 60px rgba(8, 24, 18, 0.35);
}
.dm-pop__t {
  font-size: 18px;
  font-weight: 800;
  color: var(--text);
}
.dm-pop__d {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.6;
  margin-top: 8px;
}
.dm-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 16px;
  padding: 12px 0;
  border-top: 1px solid var(--border);
}
.dm-row__t {
  font-size: 14.5px;
  font-weight: 600;
  color: var(--text);
}
.dm-row__s {
  font-size: 12px;
  color: var(--muted);
  margin-top: 3px;
}
.dm-ta {
  width: 100%;
  height: 120px;
  margin-top: 14px;
  padding: 12px;
  border-radius: 12px;
  background: var(--surface-2);
  border: 1px solid var(--border);
  font-size: 13px;
  color: var(--text);
  box-sizing: border-box;
}
.dm-acts {
  display: flex;
  gap: 12px;
  margin-top: 18px;
}
.dm-act {
  flex: 1;
}