<lz-bg />
<view class="inv">
  <lz-header title="邀请好友" subtitle="一人注册，得会员" />
  <view class="lz-page">
    <view wx:if="{{loading}}" class="lz-empty">加载中…</view>
    <!-- 加载失败（网络等）：带重试，不渲染空邀请码的复制/分享 -->
    <view wx:elif="{{loadError}}" class="lz-card" style="text-align: center;">
      <view class="lz-muted" style="font-size: 14px; margin-bottom: 16px;">加载失败，请检查网络后重试</view>
      <button class="lz-btn lz-btn--ghost lz-btn--lg" bindtap="retry">重试</button>
    </view>
    <block wx:else>
      <view class="lz-card lz-card--glow inv__hero">
        <view class="inv__glow"></view>
        <view class="inv__icon"><lz-icon name="gift" size="38" color="white" stroke="1.8" /></view>
        <view class="inv__title">邀请好友注册</view>
        <block wx:if="{{allowSelfRegister}}">
          <view class="inv__desc">好友用你的邀请码注册成功，你将获得 <text class="inv__hl">{{rewardDays}}</text> 天会员</view>
          <view class="inv__code-box" bindtap="copyCode" hover-class="tap-active">
            <text class="inv__code">{{inviteCode}}</text>
            <view class="inv__copy">复制</view>
          </view>
          <view class="inv__metrics">
            <view class="inv__metric">
              <view class="inv__metric-v">{{invitedCount}}</view>
              <view class="inv__metric-l">已邀请(人)</view>
            </view>
            <view class="inv__metric-divider"></view>
            <view class="inv__metric">
              <view class="inv__metric-v">{{rewardDays}}</view>
              <view class="inv__metric-l">每人得(天)</view>
            </view>
          </view>
        </block>
        <view wx:else class="inv__desc">管理员暂未开放自助注册，邀请功能暂不可用</view>
      </view>

      <block wx:if="{{allowSelfRegister}}">
        <view class="inv__steps">
          <view class="inv__step">
            <view class="inv__step-n">1</view>
            <view class="inv__step-t">分享给好友</view>
          </view>
          <view class="inv__step-line"></view>
          <view class="inv__step">
            <view class="inv__step-n">2</view>
            <view class="inv__step-t">好友注册</view>
          </view>
          <view class="inv__step-line"></view>
          <view class="inv__step">
            <view class="inv__step-n">3</view>
            <view class="inv__step-t">你得会员</view>
          </view>
        </view>
        <button class="lz-btn lz-btn--primary lz-btn--lg lz-btn--full inv__share" open-type="share">
          <lz-icon name="gift" size="18" color="white" /> 分享给好友
        </button>
        <view class="inv__tip">邀请码已自动带上，好友注册成功即刻到账</view>
      </block>
    </block>
  </view>
  <canvas type="2d" id="shareCover" class="share-cover-cv"></canvas>
</view>
