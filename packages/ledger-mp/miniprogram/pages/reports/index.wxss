.rp {
  min-height: 100vh;
  background-image: var(--bg-grad);
}
.rp .lz-card {
  margin-bottom: var(--gap);
}
.rp__hero {
  margin-bottom: var(--gap);
}
.rp__hero-label {
  font-size: 13px;
  color: var(--muted);
}
.rp__metrics {
  display: flex;
  margin-top: 18px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
}
.rp__metric {
  flex: 1;
  text-align: center;
}
.rp__m-v {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}
.rp__m-l {
  font-size: 11px;
  color: var(--faint);
  margin-top: 3px;
}
.rp__card-t {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
}
.rp__legend2 {
  display: flex;
  gap: 14px;
}
.rp__lg {
  display: flex;
  align-items: center;
  gap: 5px;
}
.rp__lg text {
  font-size: 11.5px;
  color: var(--muted);
}
.rp__mon {
  width: 34px;
  height: 28px;
  border-radius: 8px;
  background: var(--accent-soft);
  color: var(--accent-text);
  font-size: 11.5px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.rp__mon--on {
  background: var(--accent);
  color: #fff;
}
