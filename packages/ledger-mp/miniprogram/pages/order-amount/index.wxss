/* 编辑订单金额 · Mint Airy */
page {
  background: #e9f2ed;
}
.oa {
  min-height: 100vh;
  color: #19271f;
  font-family:
    -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei',
    'Segoe UI', system-ui, sans-serif;
}
.oa__body {
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 18px 16px 120px;
}
.ph {
  color: #9bab9f;
}
.oa__field {
  background: #fff;
  border-radius: 22px;
  box-shadow:
    0 8px 28px rgba(31, 107, 92, 0.09),
    0 1.5px 4px rgba(20, 40, 33, 0.04);
  padding: 18px;
}
.oa__lbl {
  margin-bottom: 10px;
  font-size: 13px;
  font-weight: 600;
  color: #6c7d75;
}
.oa__inwrap {
  display: flex;
  align-items: baseline;
  gap: 8px;
}
.oa__cur {
  font-size: 20px;
  font-weight: 700;
  color: #6c7d75;
}
.oa__in {
  flex: 1;
  height: 46px;
  border: none;
  background: transparent;
  font-size: 30px;
  font-weight: 800;
  color: #19271f;
  letter-spacing: -0.02em;
}
.oa__in--main {
  color: #2e9e78;
}
.oa__hint {
  padding: 2px 6px;
  font-size: 13px;
  color: #6c7d75;
}
.oa__bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
  background: #e9f2ed;
  border-top: 1px solid rgba(31, 107, 92, 0.1);
}
.oa__confirm {
  width: 100%;
  height: 50px;
  border: none;
  border-radius: 16px;
  background: #2e9e78;
  color: #fff;
  font-size: 16px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 20px rgba(46, 158, 120, 0.25);
}
.oa__confirm::after {
  border: none;
}
