<view class="oa">
  <lz-header title="编辑订单金额" />
  <view class="oa__body">
    <view class="oa__field">
      <view class="oa__lbl">订单总价</view>
      <view class="oa__inwrap">
        <text class="oa__cur">¥</text>
        <input class="oa__in oa__in--main" type="digit" focus value="{{totalStr}}" placeholder="0" placeholder-class="ph" bindinput="onTotal" />
      </view>
    </view>

    <view class="oa__field">
      <view class="oa__lbl">额外收入</view>
      <view class="oa__inwrap">
        <text class="oa__cur">¥</text>
        <input class="oa__in" type="digit" value="{{extraStr}}" placeholder="0" placeholder-class="ph" bindinput="onExtra" />
      </view>
    </view>

    <view class="oa__hint">营收合计 {{revenueText}}（订单总价 + 额外收入）</view>
  </view>

  <view class="oa__bar">
    <button class="oa__confirm" bindtap="confirm">确定</button>
  </view>
</view>
