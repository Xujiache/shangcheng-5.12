.ab__brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24px 0 28px;
}
.ab__logo-img {
  width: 64%;
  height: 64%;
  border-radius: 14px;
}
.ab__logo {
  width: 76px;
  height: 76px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #3ba58c, var(--accent));
  box-shadow: 0 16px 36px rgba(14, 124, 102, 0.3), inset 0 1px 1px rgba(255, 255, 255, 0.35);
}
.ab__name {
  font-size: 22px;
  font-weight: 800;
  letter-spacing: -0.01em;
  color: var(--text);
  margin-top: 16px;
}
.ab__ver {
  font-size: 13px;
  color: var(--muted);
  margin-top: 6px;
}
.ab__copyright {
  font-size: 11.5px;
  color: var(--faint);
  text-align: center;
  line-height: 1.7;
  white-space: pre-line;
  padding: 28px 10px 4px;
}
