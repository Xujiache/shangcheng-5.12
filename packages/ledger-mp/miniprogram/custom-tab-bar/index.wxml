<view class="ctb">
  <view
    class="ctb__bar {{glass ? '' : 'ctb__bar--solid'}}"
    style="{{glass ? barStyle : ''}}"
    bindtouchstart="onTouchStart"
    catchtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
    bindtouchcancel="onTouchEnd"
  >
    <view wx:if="{{liquid}}" class="ctb__ind {{pressed ? 'ctb__ind--press' : ''}}" style="{{indStyle}}"></view>

    <view class="ctb__tab" data-index="0" bindtap="switchTab" hover-class="tap-active">
      <view class="ctb__ic">
        <view class="ctb__ic-l" style="opacity:{{selected===0?1:0}}">
          <lz-icon name="home" size="23" color="accent" stroke="2.1" />
        </view>
        <view class="ctb__ic-l" style="opacity:{{selected===0?0:1}}">
          <lz-icon name="home" size="23" color="muted" stroke="1.8" />
        </view>
      </view>
      <text class="ctb__t {{selected===0?'ctb__t--on':''}}">首页</text>
    </view>

    <view class="ctb__tab" data-index="1" bindtap="switchTab" hover-class="tap-active">
      <view class="ctb__ic">
        <view class="ctb__ic-l" style="opacity:{{selected===1?1:0}}">
          <lz-icon name="orders" size="23" color="accent" stroke="2.1" />
        </view>
        <view class="ctb__ic-l" style="opacity:{{selected===1?0:1}}">
          <lz-icon name="orders" size="23" color="muted" stroke="1.8" />
        </view>
      </view>
      <text class="ctb__t {{selected===1?'ctb__t--on':''}}">订单</text>
    </view>

    <view class="ctb__fab" bindtap="onAdd" hover-class="tap-active">
      <lz-icon name="plus" size="27" color="white" stroke="2.3" />
    </view>

    <view class="ctb__tab" data-index="2" bindtap="switchTab" hover-class="tap-active">
      <view class="ctb__ic">
        <view class="ctb__ic-l" style="opacity:{{selected===2?1:0}}">
          <lz-icon name="trend" size="23" color="accent" stroke="2.1" />
        </view>
        <view class="ctb__ic-l" style="opacity:{{selected===2?0:1}}">
          <lz-icon name="trend" size="23" color="muted" stroke="1.8" />
        </view>
      </view>
      <text class="ctb__t {{selected===2?'ctb__t--on':''}}">报表</text>
    </view>

    <view class="ctb__tab" data-index="3" bindtap="switchTab" hover-class="tap-active">
      <view class="ctb__ic">
        <view class="ctb__ic-l" style="opacity:{{selected===3?1:0}}">
          <lz-icon name="user" size="23" color="accent" stroke="2.1" />
        </view>
        <view class="ctb__ic-l" style="opacity:{{selected===3?0:1}}">
          <lz-icon name="user" size="23" color="muted" stroke="1.8" />
        </view>
      </view>
      <text class="ctb__t {{selected===3?'ctb__t--on':''}}">我的</text>
    </view>
  </view>
</view>
