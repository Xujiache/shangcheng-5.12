/* 注意：自定义 tabBar 渲染在独立上下文，拿不到 page 作用域的 CSS 变量，
   故此处颜色全部写死（取自 styles/tokens.wxss），不要用 var(--xxx)。 */
.ctb {
  position: fixed;
  left: 12px;
  right: 12px;
  bottom: calc(14px + env(safe-area-inset-bottom));
  z-index: 100;
}
.ctb__bar {
  position: relative;
  display: flex;
  align-items: center;
  height: 66px;
  padding: 0 6px;
  border-radius: 30px;
  /* 液态玻璃：顶亮底暗的半透明渐变镜面（光线在玻璃上的折射感）*/
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0.32) 100%);
  border: 1px solid rgba(255, 255, 255, 0.6);
  /* 外阴影做悬浮 + 内嵌高光做"被光照亮的玻璃边缘"(edge lensing) */
  box-shadow:
    0 16px 48px rgba(8, 24, 18, 0.26),
    0 2px 8px rgba(8, 24, 18, 0.1),
    0 0 26px -6px rgba(46, 180, 150, 0.35),
    inset 0 1.5px 1px rgba(255, 255, 255, 0.96),
    inset 0 -2px 8px rgba(255, 255, 255, 0.45);
  /* iOS WKWebView 必须带 -webkit- 前缀，否则毛玻璃不生效 */
  -webkit-backdrop-filter: blur(20px) saturate(175%);
  backdrop-filter: blur(20px) saturate(175%);
}
/* 关闭玻璃质感：实色不透明、无模糊 */
.ctb__bar--solid {
  background: #ffffff;
  border: 1px solid rgba(20, 32, 28, 0.08);
  -webkit-backdrop-filter: none;
  backdrop-filter: none;
}
/* 液态指示块：磨砂半透明的圆角高亮，随选中 tab 滑动；切换时先拉长跨越再收拢回弹。
   置于图标下层（z-index:0），left/width 过渡带轻微回弹缓动做出液态感。 */
.ctb__ind {
  position: absolute;
  top: 11px;
  height: 44px;
  z-index: 0;
  width: 0;
  opacity: 0;
  border-radius: 16px;
  pointer-events: none;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.6) 0%, rgba(46, 180, 150, 0.18) 100%);
  border: 1px solid rgba(255, 255, 255, 0.72);
  box-shadow:
    inset 0 1.5px 1px rgba(255, 255, 255, 0.95),
    inset 0 -3px 7px rgba(46, 180, 150, 0.2),
    0 5px 14px -5px rgba(14, 124, 102, 0.5);
  -webkit-backdrop-filter: blur(6px) saturate(165%);
  backdrop-filter: blur(6px) saturate(165%);
  transition:
    left 0.42s cubic-bezier(0.34, 1.36, 0.5, 1),
    width 0.42s cubic-bezier(0.34, 1.36, 0.5, 1);
  will-change: left, width;
}
/* 无动画定位（首次出现 / 先落到来源位）*/
.ctb__ind--snap {
  transition: none;
}
.ctb__tab {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  padding: 2px 0;
}
.ctb__t {
  font-size: 10.5px;
  font-weight: 500;
  letter-spacing: 0.02em;
  color: #5c6b64;
}
.ctb__t--on {
  color: #0e7c66;
  font-weight: 700;
}
.ctb__fab {
  position: relative;
  z-index: 2;
  overflow: hidden;
  width: 56px;
  height: 56px;
  margin: 0 10px;
  flex-shrink: 0;
  border-radius: 50%;
  border: 3px solid #ffffff;
  transform: translateY(-14px);
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(150deg, #3ba58c, #0e7c66);
  box-shadow:
    0 8px 20px rgba(14, 124, 102, 0.42),
    inset 0 2px 3px rgba(255, 255, 255, 0.45),
    inset 0 -3px 6px rgba(0, 56, 42, 0.28);
}

/* FAB 点击消散光（tabBar 独立上下文，关键帧本地定义）*/
.ctb__fab::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  transform: translate(-50%, -50%) scale(0);
  background: radial-gradient(circle, rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0));
  opacity: 0;
  pointer-events: none;
}
.ctb__fab:active::after {
  animation: ctbBurst 0.55s ease-out;
}
@keyframes ctbBurst {
  0% { transform: translate(-50%, -50%) scale(0); opacity: 0.75; }
  100% { transform: translate(-50%, -50%) scale(20); opacity: 0; }
}
