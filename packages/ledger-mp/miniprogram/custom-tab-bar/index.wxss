/* 注意：自定义 tabBar 渲染在独立上下文，拿不到 page 作用域的 CSS 变量，
   故此处颜色全部写死（取自 styles/tokens.wxss），不要用 var(--xxx)。 */
.ctb {
  position: fixed;
  left: 12px;
  right: 12px;
  bottom: calc(14px + env(safe-area-inset-bottom));
  z-index: 100;
}
.ctb__bar {
  position: relative;
  display: flex;
  align-items: center;
  height: 66px;
  padding: 0 6px;
  border-radius: 30px;
  background: rgba(255, 255, 255, 0.8);
  border: 1px solid rgba(255, 255, 255, 0.55);
  box-shadow: 0 10px 34px rgba(8, 24, 18, 0.2), 0 2px 6px rgba(8, 24, 18, 0.08);
  /* iOS WKWebView 必须带 -webkit- 前缀，否则毛玻璃不生效 */
  -webkit-backdrop-filter: blur(22px) saturate(180%);
  backdrop-filter: blur(22px) saturate(180%);
}
/* 关闭玻璃质感：实色不透明、无模糊 */
.ctb__bar--solid {
  background: #ffffff;
  border: 1px solid rgba(20, 32, 28, 0.08);
  -webkit-backdrop-filter: none;
  backdrop-filter: none;
}
.ctb__tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  padding: 2px 0;
}
.ctb__t {
  font-size: 10.5px;
  font-weight: 500;
  letter-spacing: 0.02em;
  color: #5c6b64;
}
.ctb__t--on {
  color: #0e7c66;
  font-weight: 700;
}
.ctb__fab {
  width: 56px;
  height: 56px;
  margin: 0 10px;
  flex-shrink: 0;
  border-radius: 50%;
  border: 3px solid #ffffff;
  transform: translateY(-14px);
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(150deg, #3ba58c, #0e7c66);
  box-shadow: 0 8px 20px rgba(14, 124, 102, 0.42);
}
