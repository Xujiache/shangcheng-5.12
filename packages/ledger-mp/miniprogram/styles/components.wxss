/* 门窗利账 · 全局样式原语（lz-*）。app.wxss 已 @import。 */

/* 页面容器：自定义导航下的内容区 */
.lz-page {
  min-height: 100vh;
  padding: 0 18px;
  box-sizing: border-box;
}
.lz-page--pad-bottom { padding-bottom: 120px; }

/* 安全区顶部占位（自定义导航） */
.lz-safe-top { height: calc(env(safe-area-inset-top) + 44px); }

/* 卡片 */
.lz-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-card);
  padding: var(--pad);
  box-shadow: var(--shadow-soft);
}
.lz-card--glow { box-shadow: var(--shadow); }
.lz-card--flush { padding: 2px 16px; }

.lz-gap { height: var(--gap); }

/* 按钮 */
.lz-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  height: 46px;
  padding: 0 18px;
  border-radius: var(--r-btn);
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 0.01em;
  border: none;
  line-height: 1;
}
.lz-btn--lg { height: 54px; font-size: 16.5px; }
.lz-btn--sm { height: 38px; font-size: 14px; padding: 0 14px; }
.lz-btn--full { width: 100%; }
.lz-btn--primary {
  background: var(--accent);
  color: #fff;
  box-shadow: 0 8px 22px rgba(14, 124, 102, 0.32);
}
.lz-btn--soft { background: var(--accent-soft); color: var(--accent-text); }
.lz-btn--ghost { background: var(--surface); color: var(--text); border: 1px solid var(--border); box-shadow: var(--shadow-soft); }
.lz-btn--danger { background: transparent; color: var(--loss); border: 1px solid rgba(200, 68, 43, 0.3); }
.lz-btn--disabled { opacity: 0.45; pointer-events: none; }

/* 胶囊 */
.lz-pill {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  padding: 2px 8px;
  border-radius: 999px;
  font-size: 11.5px;
  font-weight: 600;
  white-space: nowrap;
}
.lz-pill--md { padding: 4px 9px; font-size: 12.5px; }
.lz-pill--profit { color: var(--profit); background: rgba(14, 124, 102, 0.12); }
.lz-pill--loss { color: var(--loss); background: rgba(200, 68, 43, 0.12); }
.lz-pill--neutral { color: var(--muted); background: var(--track); }
.lz-pill--gold { color: #8a6a18; background: rgba(244, 213, 138, 0.28); }

/* 圆点 */
.lz-dot { width: 9px; height: 9px; border-radius: 3px; flex-shrink: 0; }

/* 区块标题 */
.lz-section-label {
  font-size: 12.5px;
  color: var(--muted);
  font-weight: 500;
  margin: 6px 6px 8px;
}

/* 列表行 */
.lz-row {
  display: flex;
  align-items: center;
  gap: 12px;
  min-height: 54px;
  border-bottom: 1px solid var(--border);
}
.lz-row--last, .lz-row:last-child { border-bottom: none; }
.lz-row__icon {
  width: 32px;
  height: 32px;
  border-radius: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: var(--accent-soft);
}
.lz-row__main { flex: 1; min-width: 0; }
.lz-row__label { font-size: 15px; color: var(--text); }
.lz-row__sub { font-size: 12px; color: var(--faint); margin-top: 2px; }
.lz-row__detail { font-size: 13px; color: var(--muted); flex-shrink: 0; }
.lz-row__label--danger { color: var(--loss); }

/* 头像（渐变底 + 首字） */
.lz-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32%;
  flex-shrink: 0;
  overflow: hidden;
  color: #fff;
  font-weight: 600;
  background: linear-gradient(140deg, #3ba58c 0%, var(--accent) 100%);
  box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.3);
}

/* 金额 */
.lz-money { display: inline-flex; align-items: baseline; font-variant-numeric: tabular-nums; letter-spacing: -0.01em; font-weight: 700; color: var(--text); }
.lz-money--loss { color: var(--loss); }
.lz-money--muted { color: var(--muted); }
.lz-money--accent { color: var(--accent-text); }
.lz-cur { font-size: 0.62em; opacity: 0.78; margin-right: 1px; }

/* 输入字段行 */
.lz-field {
  display: flex;
  align-items: center;
  gap: 12px;
  height: 56px;
  padding: 0 16px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-btn);
  box-shadow: var(--shadow-soft);
}
.lz-field__input { flex: 1; min-width: 0; font-size: 15.5px; color: var(--text); font-weight: 500; }

/* 虚线添加 chip */
.lz-chip {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 6px 12px;
  border-radius: 999px;
  border: 1px dashed var(--border-strong);
  background: transparent;
  color: var(--muted);
  font-size: 12.5px;
}

/* 固定底部操作栏 */
.lz-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12px 18px calc(18px + env(safe-area-inset-bottom));
  background: var(--surface);
  border-top: 1px solid var(--border);
  z-index: 40;
}

/* 进度条 */
.lz-track { height: 7px; border-radius: 999px; background: var(--track); overflow: hidden; }
.lz-track__fill { height: 100%; border-radius: 999px; background: var(--accent); }

/* 空态 */
.lz-empty { text-align: center; color: var(--faint); font-size: 13.5px; padding: 40px 0; }

/* 文本工具 */
.lz-muted { color: var(--muted); }
.lz-faint { color: var(--faint); }
.lz-bold { font-weight: 700; }
.lz-nowrap { white-space: nowrap; }
.lz-flex { display: flex; align-items: center; }
.lz-flex1 { flex: 1; }
.lz-between { display: flex; align-items: center; justify-content: space-between; }
