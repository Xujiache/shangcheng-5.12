{
  "compilerOptions": {
    "target": "ES2018",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "experimentalDecorators": true,
    "allowJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2018"],
    "types": ["miniprogram-api-typings"]
  },
  "include": ["miniprogram/**/*.ts"],
  "exclude": ["node_modules"]
}
