{
  "name": "@jiujiu/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "经纬科技共享层：design tokens、TS 类型、Mock 生成器、工具、图标",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "import": "./src/tokens/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    },
    "./mock": {
      "types": "./src/mock/index.ts",
      "import": "./src/mock/index.ts"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "import": "./src/utils/index.ts"
    },
    "./tokens.scss": "./src/tokens/tokens.scss",
    "./tokens.css": "./src/tokens/tokens.css"
  },
  "files": [
    "dist",
    "src/tokens/tokens.scss",
    "src/tokens/tokens.css",
    "src/icons"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: shared'",
    "test": "echo 'test: shared'"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.3",
    "dayjs": "^1.11.21",
    "nanoid": "^5.1.15"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "~5.6.3"
  }
}
