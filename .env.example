# ============== 通用 ==============
NODE_ENV=production
TZ=Asia/Shanghai

# ============== 后端 NestJS ==============
# 端口口径（三处不同，勿混淆）：
#   - 生产 PM2：SERVER_PORT=3400（本文件默认值）
#   - 本机开发：packages/server/.env 用 3001（前端 .env.local 覆盖也指 3001）
#   - docker-compose 容器内：固定 3000（nginx 反代 server:3000）
SERVER_PORT=3400
SERVER_HOST=0.0.0.0

DATABASE_URL=postgresql://shangcheng:CHANGE_ME@127.0.0.1:5433/shangcheng_mall?schema=public
REDIS_URL=redis://127.0.0.1:6398

# 用 `openssl rand -base64 48` 生成 64 位强随机
JWT_SECRET=replace-with-strong-random-64-chars
JWT_ACCESS_TOKEN_TTL=7200
JWT_REFRESH_TOKEN_TTL=604800

# CORS 白名单（逗号分隔域名列表）
# 生产环境强烈建议显式配置；未配置时回退为允许所有源并打 warn 日志
# 本地多端联调示例：CORS_ORIGIN=http://localhost:5173,http://localhost:8080,http://localhost:8086,http://localhost:8087
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,http://localhost:8086,http://localhost:8087

# Swagger 文档默认仅在非生产环境暴露 (/api/docs)。
# 如需在生产环境临时打开调试，设置 SWAGGER_ENABLED=1（不建议长开）
SWAGGER_ENABLED=0

# ============== 微信小程序 ==============
WX_MINIAPP_APPID=
WX_MINIAPP_SECRET=

# ============== 微信支付 v3 ==============
WX_PAY_MCH_ID=
WX_PAY_OFFER_ID=
WX_PAY_API_V3_KEY=
WX_PAY_CERT_SERIAL=
WX_PAY_NOTIFY_URL=https://YOUR-DOMAIN/api/v1/payments/wechat/notify
WX_PAY_REFUND_NOTIFY_URL=https://YOUR-DOMAIN/api/v1/payments/wechat/refund-notify
WX_PAY_CERT_PATH=/www/shangcheng/secrets/wxpay/apiclient_cert.pem
WX_PAY_KEY_PATH=/www/shangcheng/secrets/wxpay/apiclient_key.pem
WX_PAY_PUB_KEY_ID=
WX_PAY_PUB_KEY_PATH=/www/shangcheng/secrets/wxpay/wxpay_public_key.pem

# ============== 腾讯位置服务 ==============
TENCENT_MAP_KEY=

# ============== 短信（国阳云） ==============
# 文档：http://help.guoyangyun.com/API_manual/SendSmsBatch.html
# ⚠️ 国阳云 API 收到任何内容都先返回 code:0「成功」；变量名错了不会立即报错，
#    只能去他们后台「发送记录」看到「失败：变量不匹配」。第一次配置时务必发个测试号自查。
SMS_PROVIDER=guoyangyun
GYY_SMS_API_URL=https://api.guoyangyun.com/api/sms/smsmtm.htm
GYY_SMS_APPKEY=
GYY_SMS_APPSECRET=
GYY_SMS_SIGN=
# 模板 ID（控制台 → 模板管理 → 复制ID）。国阳云官方测试模板可用 908e94ccf08b4476ba6c876d13f084ad
GYY_SMS_TEMPLATE_LOGIN=
# 模板变量名 —— 必须和模板正文里 **xxx** 一致，含星号。例：模板正文写
# 「您的验证码是 **验证码**」则填 **验证码**；写 **code** 则填 **code**。
# 不带星号也行（代码会自动补全），但强烈建议直接带上避免歧义。
GYY_SMS_TEMPLATE_VAR=**code**
# 如果模板包含 **minute** 占位（"X 分钟内有效"），这里设有效期分钟数；默认 5。
# 国阳云官方测试模板 908e94cc... 就含这个变量，必须同时填，否则后端会标记失败。
GYY_SMS_TEMPLATE_MINUTE=5

# ============== MinIO / OSS ==============
S3_ENDPOINT=http://127.0.0.1:9200
S3_REGION=cn-east-1
S3_BUCKET=shangcheng-mall
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME
S3_PUBLIC_URL=https://YOUR-DOMAIN/oss/shangcheng-mall

# ============== 门窗利账 ledger（独立小程序，/api/v1/l/*） ==============
# 独立微信小程序的 AppID/Secret（与商城 user-mp 的 WX_MINIAPP_* 不同）。
LEDGER_WX_APPID=
LEDGER_WX_SECRET=
# ledger 会员付费的微信支付回调地址（复用 WX_PAY_* 商户证书，仅 appid/notifyUrl 覆盖）。
LEDGER_PAY_NOTIFY_URL=https://YOUR-DOMAIN/api/v1/l/pay/notify
# ledger 独立 JWT access token 有效期（秒）；缺省回退 JWT_ACCESS_TOKEN_TTL。
JWT_LEDGER_TOKEN_TTL=7200
# 导出数据包的签名密钥（敏感，仅占位，请运维注入真实值）。
LEDGER_EXPORT_SECRET=replace-with-strong-random
# 小程序虚拟支付（会员等虚拟商品的合规内购；两者齐备才启用，否则自动回退「留言找管理员」）。
# 在微信公众平台「虚拟支付」开通后取得：offerId（道具项目号）、AppKey（服务端签名密钥，敏感）。
LEDGER_XPAY_OFFER_ID=
LEDGER_XPAY_APP_KEY=
# 虚拟支付环境：0=现网（默认，iOS 无沙箱），1=沙箱。
LEDGER_XPAY_ENV=0
# 套餐 key → 道具 productId 的 JSON 映射，例如 {"month":"prod_month","year":"prod_year"}；不配则用套餐 key。
LEDGER_XPAY_PRODUCTS=

# ============== AI 生图（LK888，用于 ledger 分享封面 / 素材） ==============
LK_IMAGE_BASE_URL=https://api.lk888.example
# 敏感：可计费 API Key，仅占位，切勿提交真实值；真实值由运维注入环境变量。
LK_IMAGE_API_KEY=

# ============== 分享 / 推广落地页 ==============
# 推广拉新落地页与分享短链基址（用于生成带 ?ref 的邀请链接 / 分享卡片）。
PROMOTE_LANDING_URL=https://YOUR-DOMAIN/promote
SHARE_BASE_URL=https://YOUR-DOMAIN/s
PUBLIC_SHARE_BASE_URL=https://YOUR-DOMAIN/share

# ============== 前端构建占位 ==============
# 后端统一入口 —— 4 端前端 (admin-pc / user-mp / merchant-app / platform-app)
# 默认都连这个 URL,不需要本地起 server。
# 切换到本机调试时再覆盖为 http://localhost:3001
VITE_USE_MOCK=false
VITE_API_BASE_URL=https://ewsn.top
