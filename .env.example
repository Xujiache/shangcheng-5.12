# ============== 通用 ==============
NODE_ENV=production
TZ=Asia/Shanghai

# ============== 后端 NestJS ==============
SERVER_PORT=3400
SERVER_HOST=0.0.0.0

DATABASE_URL=postgresql://shangcheng:CHANGE_ME@127.0.0.1:5433/shangcheng_mall?schema=public
REDIS_URL=redis://127.0.0.1:6398

# 用 `openssl rand -base64 48` 生成 64 位强随机
JWT_SECRET=replace-with-strong-random-64-chars
JWT_ACCESS_TOKEN_TTL=7200
JWT_REFRESH_TOKEN_TTL=604800

# ============== 微信小程序 ==============
WX_MINIAPP_APPID=
WX_MINIAPP_SECRET=

# ============== 微信支付 v3 ==============
WX_PAY_MCH_ID=
WX_PAY_OFFER_ID=
WX_PAY_API_V3_KEY=
WX_PAY_CERT_SERIAL=
WX_PAY_NOTIFY_URL=https://YOUR-DOMAIN/api/v1/payments/wechat/notify
WX_PAY_CERT_PATH=/www/shangcheng/secrets/wxpay/apiclient_cert.pem
WX_PAY_KEY_PATH=/www/shangcheng/secrets/wxpay/apiclient_key.pem
WX_PAY_PUB_KEY_ID=
WX_PAY_PUB_KEY_PATH=/www/shangcheng/secrets/wxpay/wxpay_public_key.pem

# ============== 腾讯位置服务 ==============
TENCENT_MAP_KEY=

# ============== 短信（国阳云） ==============
# 文档：http://help.guoyangyun.com/API_manual/SendSmsBatch.html
# ⚠️ 国阳云 API 收到任何内容都先返回 code:0「成功」；变量名错了不会立即报错，
#    只能去他们后台「发送记录」看到「失败：变量不匹配」。第一次配置时务必发个测试号自查。
SMS_PROVIDER=guoyangyun
GYY_SMS_API_URL=https://api.guoyangyun.com/api/sms/smsmtm.htm
GYY_SMS_APPKEY=
GYY_SMS_APPSECRET=
GYY_SMS_SIGN=
# 模板 ID（控制台 → 模板管理 → 复制ID）。国阳云官方测试模板可用 908e94ccf08b4476ba6c876d13f084ad
GYY_SMS_TEMPLATE_LOGIN=
# 模板变量名 —— 必须和模板正文里 **xxx** 一致，含星号。例：模板正文写
# 「您的验证码是 **验证码**」则填 **验证码**；写 **code** 则填 **code**。
# 不带星号也行（代码会自动补全），但强烈建议直接带上避免歧义。
GYY_SMS_TEMPLATE_VAR=**code**
# 如果模板包含 **minute** 占位（"X 分钟内有效"），这里设有效期分钟数；默认 5。
# 国阳云官方测试模板 908e94cc... 就含这个变量，必须同时填，否则后端会标记失败。
GYY_SMS_TEMPLATE_MINUTE=5

# ============== MinIO / OSS ==============
S3_ENDPOINT=http://127.0.0.1:9200
S3_REGION=cn-east-1
S3_BUCKET=shangcheng-mall
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME
S3_PUBLIC_URL=https://YOUR-DOMAIN/oss/shangcheng-mall

# ============== 前端构建占位 ==============
VITE_USE_MOCK=false
VITE_API_BASE_URL=
