# ============== 通用 ==============
NODE_ENV=development
TZ=Asia/Shanghai

# ============== 前端 ==============
# Mock 开关：true=本地 mock，false=接真实后端
VITE_USE_MOCK=true
# 后端基础地址（不含 /api/v1，路径已在 service URL 中写明）
VITE_API_BASE_URL=http://localhost:3000

# ============== 后端 NestJS ==============
SERVER_PORT=3000
SERVER_HOST=0.0.0.0

# 数据库（Docker Compose 默认）
DATABASE_URL=postgresql://jiujiu:jiujiu_dev_pwd@localhost:5433/jiujiu_mall?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=please-change-me-in-production
JWT_ACCESS_TOKEN_TTL=7200
JWT_REFRESH_TOKEN_TTL=604800

# 微信小程序（用户端）
WX_MINIAPP_APPID=your-wx-miniapp-appid
WX_MINIAPP_SECRET=your-wx-miniapp-secret

# 微信支付
WX_PAY_MCH_ID=your-mch-id
WX_PAY_API_KEY=your-api-key
WX_PAY_NOTIFY_URL=https://your-domain/api/v1/payments/wechat/notify

# 短信（阿里云 SMS，可选）
ALIYUN_SMS_KEY=
ALIYUN_SMS_SECRET=
ALIYUN_SMS_SIGN=
ALIYUN_SMS_TEMPLATE_LOGIN=

# MinIO / OSS
S3_ENDPOINT=http://localhost:9000
S3_REGION=cn-east-1
S3_BUCKET=jiujiu-mall
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_dev
S3_PUBLIC_URL=http://localhost:9000/jiujiu-mall
